---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: 'de' | 'en';
  canonicalSlug?: string;
  altSlug?: string;
  noindex?: boolean;
}

const { title, description, lang, canonicalSlug, altSlug: altSlugProp, noindex = false } = Astro.props;
const altLang = lang === 'de' ? 'en' : 'de';
const slug = canonicalSlug !== undefined ? canonicalSlug : Astro.url.pathname.replace(`/${lang}/`, '');
const altSlug = altSlugProp !== undefined ? altSlugProp : slug;
const selfHref = `https://loadouts.info/${lang}/${slug}`;
const altHref = `https://loadouts.info/${altLang}/${altSlug}`;
const deHref = lang === 'de' ? selfHref : altHref;

const nav = lang === 'de' ? {
  home: 'Start',
  tools: 'Rechner',
  vorsorge: 'Vorsorge',
  contact: 'Kontakt',
  toolItems: [
    { name: 'Säule 3a Rechner', href: '/de/saeule-3a-rechner' },
    { name: 'Lohnrechner Netto/Brutto', href: '/de/lohnrechner' },
    { name: 'Hypothek-Tragbarkeit', href: '/de/hypothek-tragbarkeit' },
    { name: 'SARON-Hypothek', href: '/de/saron-hypothek-rechner' },
  ],
} : {
  home: 'Home',
  tools: 'Calculators',
  vorsorge: 'Pension',
  contact: 'Contact',
  toolItems: [
    { name: 'Pillar 3a Calculator', href: '/en/pillar-3a-calculator' },
    { name: 'Salary Calculator', href: '/en/salary-calculator' },
    { name: 'Mortgage Affordability', href: '/en/mortgage-affordability' },
    { name: 'SARON Mortgage', href: '/en/saron-mortgage-calculator' },
  ],
};

const footer = lang === 'de' ? {
  rechner: 'Rechner',
  rechtliches: 'Rechtliches',
  kontakt: 'Kontakt',
  impressum: 'Impressum',
  datenschutz: 'Datenschutz',
  disclaimer: 'Die Berechnungen auf loadouts.info sind unverbindliche Schätzungen und stellen keine Anlage-, Steuer- oder Rechtsberatung dar.',
  feedback: 'Feedback senden',
} : {
  rechner: 'Calculators',
  rechtliches: 'Legal',
  kontakt: 'Contact',
  impressum: 'Imprint',
  datenschutz: 'Privacy',
  disclaimer: 'Calculations on loadouts.info are non-binding estimates and do not constitute financial, tax, or legal advice.',
  feedback: 'Send feedback',
};
---
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={selfHref} />
  <link rel="alternate" hreflang={lang} href={selfHref} />
  <link rel="alternate" hreflang={altLang} href={altHref} />
  <link rel="alternate" hreflang="x-default" href={deHref} />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body class="bg-[#FAFAF9] text-[#4B5563] font-sans min-h-screen flex flex-col">
  <!-- Header -->
  <header class="border-b border-gray-200 bg-white sticky top-0 z-50">
    <nav class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
      <a href={`/${lang}/`} class="text-xl font-bold text-[#1E3A8A]">loadouts.info</a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-6 text-sm">
        <a href={`/${lang}/`} class="hover:text-[#1E3A8A] transition-colors">{nav.home}</a>
        <div class="relative group">
          <button class="hover:text-[#1E3A8A] transition-colors flex items-center gap-1">
            {nav.tools}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all">
            <div class="bg-white rounded-lg shadow-lg border border-gray-200 py-2 min-w-[220px]">
              {nav.toolItems.map(item => (
                <a href={item.href} class="block px-4 py-2 text-sm hover:bg-gray-50 hover:text-[#1E3A8A] transition-colors">{item.name}</a>
              ))}
            </div>
          </div>
        </div>
        <a href="mailto:feedback@loadouts.info" class="hover:text-[#1E3A8A] transition-colors">{nav.contact}</a>
        <a href={`/${altLang}${Astro.url.pathname.replace(`/${lang}`, '')}`}
          class="bg-[#059669] text-white px-3 py-1 rounded-md font-medium hover:bg-[#047857] transition-colors">
          {altLang.toUpperCase()}
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button class="md:hidden p-2 -mr-2 min-w-[44px] min-h-[44px] flex items-center justify-center" onclick="document.getElementById('mobile-menu').classList.toggle('hidden')" aria-label="Menu">
        <svg class="h-6 w-6 text-[#4B5563]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-4 py-3 space-y-2">
      <a href={`/${lang}/`} class="block py-2 text-sm hover:text-[#1E3A8A]">{nav.home}</a>
      {nav.toolItems.map(item => (
        <a href={item.href} class="block py-2 text-sm hover:text-[#1E3A8A] pl-4">{item.name}</a>
      ))}
      <a href="mailto:feedback@loadouts.info" class="block py-2 text-sm hover:text-[#1E3A8A]">{nav.contact}</a>
      <a href={`/${altLang}${Astro.url.pathname.replace(`/${lang}`, '')}`}
        class="block py-2 text-sm text-[#059669] font-medium">
        {altLang === 'de' ? 'Deutsch' : 'English'}
      </a>
    </div>
  </header>

  <!-- Main -->
  <main class="max-w-5xl mx-auto px-4 py-8 flex-1 w-full">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="border-t border-gray-200 bg-white mt-16">
    <div class="max-w-5xl mx-auto px-4 py-10">
      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-8">
        <!-- Rechner -->
        <div>
          <h4 class="font-semibold text-[#1E3A8A] mb-3">{footer.rechner}</h4>
          <ul class="space-y-2 text-sm">
            {nav.toolItems.map(item => (
              <li><a href={item.href} class="hover:text-[#1E3A8A] transition-colors">{item.name}</a></li>
            ))}
          </ul>
        </div>

        <!-- Rechtliches -->
        <div>
          <h4 class="font-semibold text-[#1E3A8A] mb-3">{footer.rechtliches}</h4>
          <ul class="space-y-2 text-sm">
            <li><a href={`/${lang}/${lang === 'de' ? 'impressum' : 'imprint'}`} class="hover:text-[#1E3A8A] transition-colors">{footer.impressum}</a></li>
            <li><a href={`/${lang}/${lang === 'de' ? 'datenschutz' : 'privacy'}`} class="hover:text-[#1E3A8A] transition-colors">{footer.datenschutz}</a></li>
          </ul>
        </div>

        <!-- Kontakt -->
        <div>
          <h4 class="font-semibold text-[#1E3A8A] mb-3">{footer.kontakt}</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="mailto:feedback@loadouts.info" class="hover:text-[#1E3A8A] transition-colors">{footer.feedback}</a></li>
          </ul>
        </div>

        <!-- Sprache -->
        <div>
          <h4 class="font-semibold text-[#1E3A8A] mb-3">{lang === 'de' ? 'Sprache' : 'Language'}</h4>
          <a href={`/${altLang}${Astro.url.pathname.replace(`/${lang}`, '')}`}
            class="inline-block bg-gray-100 px-3 py-1.5 rounded-md text-sm font-medium hover:bg-gray-200 transition-colors">
            {altLang === 'de' ? 'Deutsch' : 'English'}
          </a>
        </div>
      </div>

      <div class="border-t border-gray-100 mt-8 pt-6">
        <p class="text-xs text-[#4B5563] leading-relaxed">{footer.disclaimer}</p>
        <p class="text-xs text-[#4B5563] mt-2">&copy; {new Date().getFullYear()} loadouts.info. {lang === 'de' ? 'Alle Rechte vorbehalten.' : 'All rights reserved.'}</p>
      </div>
    </div>
  </footer>
</body>
</html>
