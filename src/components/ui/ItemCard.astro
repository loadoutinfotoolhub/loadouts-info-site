---
import PriceTag from './PriceTag.astro';
import StatBar from './StatBar.astro';
import GoLink from './GoLink.astro';
import type { LoadoutItem } from '@/content.config';
import { ui } from '@/data/i18n';

interface Props {
  item: LoadoutItem;
  lang: 'de' | 'en';
  showStats?: boolean;
  showProsCons?: boolean;
  showBegruendung?: boolean;
  hero?: boolean;
}

const {
  item,
  lang,
  showStats = false,
  showProsCons = false,
  showBegruendung = true,
  hero = false,
} = Astro.props;

const name = lang === 'de' ? item.name_de : item.name_en;
const begruendung = lang === 'de' ? item.begruendung_de : item.begruendung_en;
const pros = lang === 'de' ? item.pros_de : item.pros_en;
const cons = lang === 'de' ? item.cons_de : item.cons_en;
const statLabels: Record<string, { de: string; en: string }> = {
  qualitaet:      { de: 'Qualität',       en: 'Quality' },
  komfort:        { de: 'Komfort',        en: 'Comfort' },
  haltbarkeit:    { de: 'Haltbarkeit',    en: 'Durability' },
  gewicht:        { de: 'Gewicht',        en: 'Weight' },
  preis_leistung: { de: 'Preis-Leistung', en: 'Value' },
};
---
<article class={`item-card rarity-${item.rarity} ${hero ? 'hero' : ''}`}>
  <header class="ic-head">
    <div class="ic-title">
      <h3>{name}</h3>
      {item.ist_neu_in_tier && <span class="ic-new">{ui[lang].new_in_tier}</span>}
    </div>
    <PriceTag price={item.price_chf} rarity={item.rarity} lang={lang} />
  </header>

  {showBegruendung && begruendung && (
    <p class="ic-reason">{begruendung}</p>
  )}

  {showStats && item.stats && (
    <div class="ic-stats">
      {Object.entries(item.stats).map(([k, v]) => (
        v !== undefined && <StatBar label={statLabels[k]?.[lang] ?? k} value={v as number} />
      ))}
    </div>
  )}

  {showProsCons && (pros.length > 0 || cons.length > 0) && (
    <div class="ic-pros-cons">
      {pros.length > 0 && (
        <ul class="ic-pros">
          {pros.map((p) => <li>+ {p}</li>)}
        </ul>
      )}
      {cons.length > 0 && (
        <ul class="ic-cons">
          {cons.map((c) => <li>− {c}</li>)}
        </ul>
      )}
    </div>
  )}

  <footer class="ic-foot">
    <GoLink slug={item.go_slug} lang={lang} />
  </footer>
</article>

<style>
  .item-card {
    background: var(--bg-surface);
    border: 2px solid var(--border-default);
    border-radius: var(--radius-card);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: transform .15s, box-shadow .2s;
  }
  .item-card:hover { transform: translateY(-2px); }
  .item-card.hero {
    grid-column: 1 / -1;
    padding: var(--space-6);
  }
  .ic-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-3);
  }
  .ic-title h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.3;
  }
  .ic-new {
    display: inline-block;
    margin-top: 4px;
    font-size: 0.65rem;
    background: var(--accent);
    color: #fff;
    padding: 1px 6px;
    border-radius: var(--radius-badge);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .ic-reason {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.85rem;
    line-height: 1.5;
  }
  .ic-stats {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ic-pros-cons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
    font-size: 0.75rem;
  }
  .ic-pros-cons ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 3px; }
  .ic-pros li { color: var(--success); }
  .ic-cons li { color: var(--danger); }
  .ic-foot { margin-top: auto; }
</style>
