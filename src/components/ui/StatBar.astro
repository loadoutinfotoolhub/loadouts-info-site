---
interface Props {
  label: string;
  value: number; // 1..5
}
const { label, value } = Astro.props;
const pct = Math.max(0, Math.min(100, (value / 5) * 100));
---
<div class="statbar">
  <span class="statbar-label">{label}</span>
  <div class="statbar-track">
    <div class="statbar-fill" style={`width:${pct}%`}></div>
  </div>
  <span class="statbar-value">{value}/5</span>
</div>

<style>
  .statbar {
    display: grid;
    grid-template-columns: 80px 1fr 32px;
    gap: 8px;
    align-items: center;
    font-size: 0.75rem;
  }
  .statbar-label { color: var(--text-muted); text-transform: capitalize; }
  .statbar-track {
    background: var(--bg-overlay);
    height: 6px;
    border-radius: 3px;
    overflow: hidden;
  }
  .statbar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-bright));
    border-radius: 3px;
  }
  .statbar-value {
    font-family: var(--font-mono);
    color: var(--text-secondary);
    font-size: 0.7rem;
    text-align: right;
  }
</style>
