---
import { ui } from '@/data/i18n';
interface Props { lang: 'de' | 'en'; }
const { lang } = Astro.props;
const t = ui[lang];
const exploreHref = lang === 'de' ? '#kategorien' : '#kategorien';
const howHref = '#how-it-works';
---
<section class="hero">
  <div class="hero-inner">
    <h1>{t.hero_title}</h1>
    <p class="sub">{t.hero_sub}</p>
    <div class="ctas">
      <a class="cta primary" href={exploreHref}>{t.hero_cta_primary}</a>
      <a class="cta secondary" href={howHref}>{t.hero_cta_secondary}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-16) var(--space-4) var(--space-12);
    background:
      radial-gradient(ellipse at top, var(--accent-glow), transparent 60%),
      var(--bg-base);
  }
  .hero-inner {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.01em;
  }
  .sub {
    margin-top: var(--space-4);
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.6;
  }
  .ctas {
    margin-top: var(--space-8);
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta {
    padding: 12px 22px;
    border-radius: var(--radius-btn);
    font-weight: 600;
    font-size: 0.95rem;
    transition: transform .15s, background .15s;
  }
  .cta.primary { background: var(--accent); color: #fff; }
  .cta.primary:hover { background: var(--accent-bright); transform: translateY(-1px); }
  .cta.secondary { background: var(--bg-surface); color: var(--text-primary); border: 1px solid var(--border-default); }
  .cta.secondary:hover { background: var(--bg-elevated); }
</style>
