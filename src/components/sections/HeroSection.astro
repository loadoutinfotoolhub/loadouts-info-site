---
import { ui } from '@/data/i18n';
import { kategorien } from '@/data/kategorien';
import Icon from '@/components/ui/Icon.astro';

interface Props { lang: 'de' | 'en'; }
const { lang } = Astro.props;
const t = ui[lang];
const catPrefix = lang === 'de' ? '/de/kategorie/' : '/en/category/';
const [line1, line2] = t.hero_title.split('. ').length > 1
  ? [t.hero_title.split('. ')[0] + '.', t.hero_title.split('. ').slice(1).join('. ')]
  : [t.hero_title, ''];
---
<section class="hero">
  <div class="hero-inner">
    <h1>
      <span class="h1-line">{line1}</span>
      {line2 && <span class="h1-line sub-head">{line2}</span>}
    </h1>
    <p class="sub">{t.hero_sub}</p>
    <div class="ctas">
      <a class="cta primary" href="#kategorien">
        <span>{t.hero_cta_primary}</span>
        <Icon name="arrow-right" size={16} />
      </a>
      <a class="cta secondary" href="#how-it-works">
        <span>{t.hero_cta_secondary}</span>
      </a>
    </div>
  </div>

  <nav class="hero-cats" aria-label="Kategorien">
    <div class="hero-cats-inner">
      {kategorien.map((k, i) => (
        <>
          {i > 0 && <span class="sep" aria-hidden="true">·</span>}
          <a class="hero-cat" href={`${catPrefix}${k.slug}`}>
            <Icon name={k.icon} size={15} />
            <span>{lang === 'de' ? k.name_de : k.name_en}</span>
          </a>
        </>
      ))}
    </div>
  </nav>
</section>

<style>
  .hero {
    padding: var(--space-16) var(--space-4) var(--space-8);
    background: var(--bg-base);
  }
  .hero-inner {
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-4xl);
    letter-spacing: -0.035em;
    line-height: 1.05;
    margin: 0;
    color: var(--text-primary);
  }
  .h1-line { display: block; }
  .sub-head {
    color: var(--text-secondary);
    font-weight: 500;
    margin-top: 0.2em;
  }
  .sub {
    margin: var(--space-6) auto 0;
    max-width: 620px;
    color: var(--text-secondary);
    font-size: var(--text-lg);
    line-height: 1.55;
  }
  .ctas {
    margin-top: var(--space-8);
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: var(--radius-btn);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    transition: transform .15s, background .15s, border-color .15s, box-shadow .15s;
  }
  .cta.primary {
    background: var(--accent);
    color: #fff;
    border: 1px solid var(--accent);
  }
  .cta.primary:hover {
    background: var(--accent-bright);
    border-color: var(--accent-bright);
    transform: translateY(-1px);
    box-shadow: 0 6px 16px var(--accent-glow);
  }
  .cta.secondary {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-default);
  }
  .cta.secondary:hover {
    border-color: var(--border-strong);
    background: var(--bg-elevated);
  }

  .hero-cats {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }
  .hero-cats-inner {
    max-width: 1180px;
    margin: 0 auto;
    padding: var(--space-4) var(--space-4);
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    scrollbar-width: none;
  }
  .hero-cats-inner::-webkit-scrollbar { display: none; }
  .hero-cat {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.875rem;
    color: var(--text-secondary);
    padding: 6px 0;
    transition: color .15s;
  }
  .hero-cat:hover { color: var(--text-primary); }
  .sep { color: var(--border-strong); }

  @media (max-width: 620px) {
    .hero-cats-inner { justify-content: flex-start; }
  }
</style>
