---
import { kategorien } from '@/data/kategorien';
import { ui } from '@/data/i18n';

interface Props { lang: 'de' | 'en'; }
const { lang } = Astro.props;
const t = ui[lang];
const prefix = lang === 'de' ? '/de/kategorie/' : '/en/category/';
---
<section class="cat-grid-section" id="kategorien">
  <div class="cat-inner">
    <header class="cat-head">
      <h2>{t.categories_title}</h2>
      <p>{t.categories_sub}</p>
    </header>
    <div class="cat-grid">
      {kategorien.map((k) => (
        <a class="cat-card" href={`${prefix}${k.slug}`}>
          <span class="cat-emoji">{k.emoji}</span>
          <span class="cat-name">{lang === 'de' ? k.name_de : k.name_en}</span>
          <span class="cat-desc">{lang === 'de' ? k.desc_de : k.desc_en}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .cat-grid-section { padding: var(--space-12) var(--space-4); }
  .cat-inner { max-width: 1180px; margin: 0 auto; }
  .cat-head { text-align: center; margin-bottom: var(--space-8); }
  .cat-head h2 { font-size: 2rem; margin: 0; }
  .cat-head p { color: var(--text-secondary); margin-top: 8px; }
  .cat-grid {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .cat-card {
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-card);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: transform .15s, border-color .15s, background .15s;
  }
  .cat-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
    background: var(--bg-elevated);
  }
  .cat-emoji { font-size: 2rem; }
  .cat-name { font-family: var(--font-display); font-weight: 700; font-size: 1.25rem; }
  .cat-desc { color: var(--text-secondary); font-size: 0.9rem; line-height: 1.5; }
</style>
