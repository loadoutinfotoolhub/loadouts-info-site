---
import { getCollection } from 'astro:content';
import TierBadge from '@/components/ui/TierBadge.astro';
import Icon from '@/components/ui/Icon.astro';
import { ui } from '@/data/i18n';
import { findKategorie } from '@/data/kategorien';

interface Props {
  slugs: readonly string[] | string[];
  lang: 'de' | 'en';
}
const { slugs, lang } = Astro.props;
const t = ui[lang];
const all = await getCollection('loadouts');
const related = slugs
  .map((s) => all.find((l) => l.data.slug === s))
  .filter((x): x is NonNullable<typeof x> => !!x);
const prefix = lang === 'de' ? '/de/loadouts/' : '/en/loadouts/';
---
{related.length > 0 && (
  <section class="related">
    <h2>{t.related_title}</h2>
    <div class="related-grid">
      {related.map((l) => {
        const kat = findKategorie(l.data.kategorie_slug);
        return (
          <a class="related-card" href={`${prefix}${l.data.slug}`}>
            <span class="rl-icon" aria-hidden="true">
              {kat && <Icon name={kat.icon} size={20} />}
            </span>
            <div class="rl-body">
              <TierBadge tier={l.data.tier} lang={lang} />
              <h3>{lang === 'de' ? l.data.name_de : l.data.name_en}</h3>
            </div>
            <span class="rl-arrow" aria-hidden="true">
              <Icon name="chevron-right" size={16} />
            </span>
          </a>
        );
      })}
    </div>
  </section>
)}

<style>
  .related { padding: var(--space-8) 0; }
  h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin: 0 0 var(--space-4);
    letter-spacing: -0.02em;
  }
  .related-grid {
    display: grid;
    gap: var(--space-3);
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }
  .related-card {
    display: flex;
    gap: var(--space-3);
    align-items: center;
    padding: var(--space-4);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-card);
    box-shadow: var(--card-shadow);
    transition: border-color .15s, transform .15s, box-shadow .2s;
  }
  .related-card:hover {
    border-color: var(--border-default);
    transform: translateY(-1px);
    box-shadow: var(--card-shadow-hover);
  }
  .rl-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--bg-elevated);
    border-radius: var(--radius-btn);
    color: var(--accent);
    flex-shrink: 0;
  }
  .rl-body { flex: 1; min-width: 0; }
  .rl-body h3 {
    margin: 6px 0 0;
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .rl-arrow { color: var(--text-muted); flex-shrink: 0; }
  .related-card:hover .rl-arrow { color: var(--accent); }
</style>
