---
import { ui } from '@/data/i18n';
interface Props {
  lang: 'de' | 'en';
  items: { q: string; a: string }[];
}
const { lang, items } = Astro.props;
---
<section class="faq">
  <h2>{ui[lang].faq_title}</h2>
  <div class="faq-list">
    {items.map((it) => (
      <details class="faq-item">
        <summary>{it.q}</summary>
        <div class="faq-answer">{it.a}</div>
      </details>
    ))}
  </div>
</section>

<style>
  .faq { padding: var(--space-8) 0; }
  h2 { font-size: 1.5rem; margin: 0 0 var(--space-4); }
  .faq-list { display: flex; flex-direction: column; gap: var(--space-2); }
  .faq-item {
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-card);
    padding: var(--space-3) var(--space-4);
  }
  summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--text-primary);
    font-size: 1rem;
    list-style: none;
  }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: '+'; float: right; color: var(--text-muted); }
  details[open] summary::after { content: '−'; }
  .faq-answer {
    margin-top: var(--space-3);
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
  }
</style>
