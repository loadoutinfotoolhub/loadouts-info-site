---
import { ui } from '@/data/i18n';

interface Props { lang: 'de' | 'en'; }
const { lang } = Astro.props;
const t = ui[lang];
const aboutPath = lang === 'de' ? '/de/ueber-uns' : '/en/about';
const tagline = lang === 'de'
  ? 'Ehrliche Empfehlungen. Kein Spam.'
  : 'Honest recommendations. No spam.';
const affiliateLabel = lang === 'de' ? 'Affiliate-Disclosure' : 'Affiliate Disclosure';
const descLine = lang === 'de'
  ? 'Die richtige Ausrüstung — für jedes Hobby, jeden Sport, jeden Lebensabschnitt.'
  : 'The right gear — for every hobby, every sport, every chapter of life.';
---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-col brand">
      <a class="footer-brand" href={`/${lang}/`}>
        <span>loadouts</span><span class="dot">.info</span>
      </a>
      <p class="footer-desc">{descLine}</p>
    </div>

    <nav class="footer-col footer-nav" aria-label="Footer">
      <a href={aboutPath}>{t.footer_about}</a>
      <a href="/impressum">{t.footer_impressum}</a>
      <a href="/datenschutz">{t.footer_datenschutz}</a>
      <a href="/affiliate-disclosure">{affiliateLabel}</a>
    </nav>

    <p class="footer-col footer-affiliate">{t.footer_affiliate}</p>
  </div>

  <div class="footer-bottom">
    <p class="footer-copy">© 2026 loadouts.info</p>
    <p class="footer-tagline">{tagline}</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-16);
    border-top: 1px solid var(--border-subtle);
    background: var(--bg-surface);
  }
  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--space-12) var(--space-4) var(--space-8);
    display: grid;
    gap: var(--space-8);
    grid-template-columns: 1fr;
  }
  .footer-col { display: flex; flex-direction: column; gap: var(--space-3); }
  .footer-brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }
  .footer-brand .dot { color: var(--accent); }
  .footer-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.55;
    margin: 0;
    max-width: 320px;
  }
  .footer-nav { gap: var(--space-2); font-size: 0.9rem; }
  .footer-nav a { color: var(--text-secondary); }
  .footer-nav a:hover { color: var(--text-primary); }
  .footer-affiliate {
    color: var(--text-muted);
    font-size: 0.8rem;
    line-height: 1.55;
    margin: 0;
  }
  .footer-bottom {
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--space-4) var(--space-4) var(--space-8);
    border-top: 1px solid var(--border-subtle);
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .footer-copy, .footer-tagline {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0;
  }

  @media (min-width: 760px) {
    .footer-inner { grid-template-columns: 1.2fr 1fr 1.5fr; gap: var(--space-12); }
  }
</style>
