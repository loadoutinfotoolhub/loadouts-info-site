---
/**
 * CharacterView.astro — Shell, rendert die interaktive Svelte-Inventory-Ansicht.
 * Layout + State (Slot-Overlay) stecken in CharacterInventory.svelte.
 */
import CharacterInventory from './CharacterInventory.svelte';
import type { LoadoutItem } from '@/content.config';
import { ui } from '@/data/i18n';

interface Props {
  items: LoadoutItem[];
  equipmentSlots: Record<string, string>;
  lang: 'de' | 'en';
}
const { items, equipmentSlots, lang } = Astro.props;
const t = ui[lang];
const closeLabel = lang === 'de' ? 'Schliessen' : 'Close';
---
<CharacterInventory
  client:load
  items={items}
  equipmentSlots={equipmentSlots}
  lang={lang}
  emptyText={t.upgrade_hint}
  closeLabel={closeLabel}
/>
