---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Kapitalbezugssteuer from '../../components/calculators/Kapitalbezugssteuer.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';

const title = 'Kapitalbezugssteuer-Rechner 2026: Saeule 3a & PK Auszahlung | loadouts.info';
const description = 'Berechne die Kapitalbezugssteuer bei Auszahlung deiner Saeule 3a oder Pensionskasse. Alle Kantone, mit gestaffeltem Bezug. Gratis.';

const federalSources = [
  { displayName: 'Eidgenoessische Steuerverwaltung ESTV', url: 'https://www.estv.admin.ch/estv/de/home/direkte-bundessteuer/kapitalauszahlungen.html', legalBasis: 'Art. 38 DBG' },
  { displayName: 'Fedlex - DBG (Bundesgesetz ueber die direkte Bundessteuer)', url: 'https://www.fedlex.admin.ch/eli/cc/1991/1184_1184_1184/de' },
  { displayName: 'Bundesamt fuer Sozialversicherungen BSV', url: 'https://www.bsv.admin.ch/de/beitrag-3-sauele' },
];

const faqs = [
  { q: 'Wie wird die Kapitalbezugssteuer berechnet?', a: 'Kapitalleistungen aus Vorsorge (Saeule 3a, Pensionskasse, Freizuegigkeit) werden separat vom uebrigen Einkommen besteuert. Der Bund wendet einen reduzierten Satz an (1/5 des ordentlichen Tarifs). Die Kantone haben eigene, teils deutlich unterschiedliche Tarife.' },
  { q: 'In welchem Kanton zahle ich am wenigsten Kapitalbezugssteuer?', a: 'Schwyz, Appenzell Innerrhoden und Zug gehoeren zu den guenstigsten Kantonen. Bern, Waadt und Basel-Stadt sind vergleichsweise teuer. Die Steuer haengt auch von der Gemeinde ab.' },
  { q: 'Lohnt sich ein gestaffelter Bezug der Saeule 3a?', a: 'Ja, in den meisten Kantonen. Da die Kapitalbezugssteuer progressiv ist, spart ein Bezug ueber mehrere Steuerjahre verteilt deutlich Steuern. Idealerweise bezieht man jedes 3a-Konto in einem separaten Jahr.' },
  { q: 'Werden Saeule 3a und Pensionskasse zusammen besteuert?', a: 'Ja, alle Kapitalleistungen aus Vorsorge im gleichen Steuerjahr werden zusammengerechnet. Das gilt fuer Saeule 3a, Pensionskasse, Freizuegigkeit und Saeulen-Vorbezuege.' },
  { q: 'Wie viele Saeule-3a-Konten soll ich fuehren?', a: 'Die gaengige Empfehlung lautet 3 bis 5 Konten, die du gestaffelt ueber mehrere Jahre aufloest. Mehr Konten bringen ab einem gewissen Punkt keinen zusaetzlichen Steuervorteil. Nutze unseren <a href="/de/saeule-3a-rechner" class="text-[#1E3A8A] underline">Saeule 3a Rechner</a> fuer die Einzahlungsplanung.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Kapitalbezugssteuer-Rechner 2026',
  url: 'https://loadouts.info/de/kapitalbezugssteuer-rechner',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'de',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: 'https://loadouts.info/de/' },
    { '@type': 'ListItem', position: 2, name: 'Kapitalbezugssteuer-Rechner', item: 'https://loadouts.info/de/kapitalbezugssteuer-rechner' },
  ],
};

const glossaryDE = [
  { term: 'Kapitalbezugssteuer', definition: 'Steuer auf einmalige Kapitalleistungen aus der Vorsorge (Saeule 3a, Pensionskasse, Freizuegigkeit). Wird separat vom uebrigen Einkommen und zu einem reduzierten Satz besteuert.' },
  { term: 'Gestaffelter Bezug', definition: 'Auszahlung von Vorsorgekapital ueber mehrere Steuerjahre verteilt. Senkt die Steuerlast, da die Kapitalbezugssteuer progressiv ist.' },
  { term: 'Freizuegigkeitskonto', definition: 'Konto, auf das dein Pensionskassenguthaben ueberwiesen wird, wenn du den Arbeitgeber wechselst und nicht sofort einer neuen PK beitrittst.' },
  { term: 'Progression', definition: 'Steigende Steuersaetze bei hoeherem Kapitalbezug. Je mehr du auf einmal beziehst, desto hoeher der prozentuale Steuersatz.' },
  { term: 'WEF-Vorbezug', definition: 'Vorbezug fuer Wohneigentum (Wohneigentumsfoerderung). Das vorbezogene Kapital wird bei Bezug besteuert, kann aber bei Rueckzahlung zurueckgefordert werden.' },
];
---
<BaseLayout title={title} description={description} lang="de" canonicalSlug="kapitalbezugssteuer-rechner" altSlug="capital-withdrawal-tax-calculator">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/de/" class="hover:text-[#1E3A8A]">Start</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Kapitalbezugssteuer-Rechner</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Kapitalbezugssteuer-Rechner 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    Die <TermTooltip client:load term="Kapitalbezugssteuer" definition="Steuer auf einmalige Kapitalleistungen aus Vorsorge. Wird separat und zu einem reduzierten Satz besteuert." />
    faellt bei der Auszahlung deiner Saeule 3a, Pensionskasse oder Freizuegigkeit an. Die Hoehe variiert
    stark nach Kanton. Ein <TermTooltip client:load term="gestaffelter Bezug" definition="Auszahlung ueber mehrere Jahre verteilt. Spart Steuern dank tieferer Progression." />
    ueber mehrere Jahre kann deine Steuerlast deutlich senken.
  </p>

  <Kapitalbezugssteuer client:load lang="de" />

  <div class="mt-12 bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-[#4B5563]">
    Die Berechnungen auf loadouts.info sind unverbindliche Schaetzungen und stellen keine Anlage-, Steuer- oder Rechtsberatung dar.
  </div>

  <SourceBox client:load federalSources={federalSources} lang="de" />

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Haeufige Fragen zur Kapitalbezugssteuer</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed" set:html={faq.a} />
        </details>
      ))}
    </div>
  </section>

  <GlossarySection client:load entries={glossaryDE} lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
