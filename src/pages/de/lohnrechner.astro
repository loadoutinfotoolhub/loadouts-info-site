---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Lohnrechner from '../../components/calculators/Lohnrechner.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';
import { CH2026 } from '../../lib/ch-constants';

const title = 'Lohnrechner Netto/Brutto 2026: Schweizer Abzüge berechnen | loadouts.info';
const description = 'Berechne sofort deinen Nettolohn aus dem Bruttolohn. Alle Abzüge: AHV, IV, EO, ALV, BVG, Steuern. 7 Kantone, gratis.';

const federalSources = [
  { displayName: 'Bundesamt für Sozialversicherungen (BSV)', url: 'https://www.bsv.admin.ch/de/beitraege-im-ueberblick', legalBasis: 'AHVG, IVG, EOG' },
  { displayName: 'Staatssekretariat für Wirtschaft (SECO)', url: 'https://www.seco.admin.ch', legalBasis: 'AVIG Art. 3' },
  { displayName: 'Informationsstelle AHV/IV', url: 'https://www.ahv-iv.ch/de/Sozialversicherungen/Beitragspflicht' },
  { displayName: 'Fedlex: BVG (Bundesgesetz)', url: 'https://www.fedlex.admin.ch/eli/cc/1983/797_797_797/de' },
];

const faqs = [
  { q: 'Welche Abzüge werden vom Bruttolohn gemacht?', a: `Standardabzüge 2026: AHV ${(CH2026.sozialversicherung.ahv * 100).toFixed(1)}%, IV ${(CH2026.sozialversicherung.iv * 100).toFixed(1)}%, EO ${(CH2026.sozialversicherung.eo * 100).toFixed(2)}%, ALV ${(CH2026.sozialversicherung.alv * 100).toFixed(1)}% (auf Einkommen bis CHF ${new Intl.NumberFormat('de-CH').format(CH2026.sozialversicherung.alvMaxEinkommen)}), Pensionskasse (variabel, typisch 7%), Steuern je nach Kanton.` },
  { q: 'Wie viel Netto bleibt bei CHF 100\'000 Brutto?', a: 'Bei alleinstehend, 30 Jahre, ohne Kirchensteuer: ca. CHF 75\'000 bis 82\'000 netto, abhängig vom Kanton. In Zug deutlich mehr als in Genf. Der Lohnrechner auf dieser Seite zeigt deinen Kanton präzise.' },
  { q: 'Was ist der 13. Monatslohn?', a: 'Eine freiwillige zusätzliche Lohnzahlung von Arbeitgebern, meist im November oder Dezember. Sie ist nicht gesetzlich vorgeschrieben, aber in den meisten Schweizer Arbeitsverträgen enthalten.' },
  { q: 'Wie wird die Pensionskasse berechnet?', a: `Ab einem Jahreslohn von CHF ${new Intl.NumberFormat('de-CH').format(CH2026.bvg.eintrittsschwelle)} (BVG-Eintrittsschwelle 2026) wird ein BVG-Beitrag fällig. Der Satz hängt vom Alter ab: 7% (25-34), 10% (35-44), 15% (45-54), 18% (55-65). Arbeitgeber und Arbeitnehmer teilen typisch je 50%.` },
  { q: 'Was ist der AHV-Koordinationsabzug?', a: `Für die Pensionskasse wird ein Koordinationsabzug von CHF ${new Intl.NumberFormat('de-CH').format(CH2026.bvg.koordinationsabzug)} (2026) gemacht. Nur der Lohnanteil darüber bis CHF ${new Intl.NumberFormat('de-CH').format(CH2026.bvg.maxVersLohn)} ist obligatorisch BVG-versichert.` },
  { q: 'Muss ich Kirchensteuer zahlen?', a: 'Nur wenn du Mitglied einer Landeskirche bist (kath., ref., christkath.). Bei Austritt entfällt die Kirchensteuer. Der Zuschlag beträgt je nach Kanton 6-12% auf die Kantonssteuer.' },
  { q: 'Was ist der Grenzsteuersatz?', a: 'Der Steuersatz, der auf den letzten Franken deines Einkommens anfällt. Wichtig für die Säule-3a-Berechnung: Jeder in die 3a einbezahlte Franken spart dir genau diesen Prozentsatz an Steuern.' },
  { q: 'Wie hoch ist der Medianlohn in der Schweiz?', a: 'Laut BFS Lohnstrukturerhebung liegt der Medianlohn bei ca. CHF 85\'000 brutto pro Jahr (Vollzeit). Frauen verdienen im Schnitt ca. 8-15% weniger.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Lohnrechner Netto/Brutto 2026',
  url: 'https://loadouts.info/de/lohnrechner',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'de',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: 'https://loadouts.info/de/' },
    { '@type': 'ListItem', position: 2, name: 'Lohnrechner', item: 'https://loadouts.info/de/lohnrechner' },
  ],
};

const glossaryDE = [
  { term: 'Bruttolohn', definition: 'Dein Lohn vor allen Abzügen. Der Betrag, der im Arbeitsvertrag steht.' },
  { term: 'Nettolohn', definition: 'Was nach allen Abzügen auf deinem Konto landet.' },
  { term: 'AHV', definition: 'Alters- und Hinterlassenenversicherung, die staatliche Rente (1. Säule). Obligatorischer Beitrag: 5.3% vom Lohn.' },
  { term: 'IV', definition: 'Invalidenversicherung. Sichert dich bei dauerhafter Erwerbsunfähigkeit ab. Beitrag: 0.7%.' },
  { term: 'EO', definition: 'Erwerbsersatzordnung. Finanziert den Lohnersatz bei Militärdienst und Mutterschaft. Beitrag: 0.25%.' },
  { term: 'ALV', definition: 'Arbeitslosenversicherung. Sichert Lohnausfall bei Stellenverlust ab. Beitrag: 1.1% bis zur Obergrenze.' },
  { term: 'BVG / Pensionskasse', definition: 'Berufliche Vorsorge (2. Säule). Obligatorisch ab einem Jahreslohn von CHF 22\'680. Beitragssatz steigt mit dem Alter.' },
  { term: 'Grenzsteuersatz', definition: 'Der Steuersatz auf den letzten verdienten Franken. Bestimmt, wie viel Steuern du bei einer Säule-3a-Einzahlung sparst.' },
  { term: 'Koordinationsabzug', definition: 'Betrag, der vom Bruttolohn abgezogen wird, bevor der BVG-Beitrag berechnet wird. Berücksichtigt, dass die AHV bereits einen Teil der Vorsorge abdeckt.' },
  { term: '13. Monatslohn', definition: 'Eine zusätzliche Monatszahlung pro Jahr, typisch in Schweizer Arbeitsverträgen. Nicht gesetzlich vorgeschrieben.' },
];
---
<BaseLayout title={title} description={description} lang="de" canonicalSlug="lohnrechner" altSlug="salary-calculator">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/de/" class="hover:text-[#1E3A8A]">Start</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Lohnrechner</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Lohnrechner Netto/Brutto 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    In der Schweiz werden vom <TermTooltip client:load term="Bruttolohn" definition="Dein Lohn vor allen Abzügen, wie er im Arbeitsvertrag steht." />
    Sozialversicherungsbeiträge (<TermTooltip client:load term="AHV" definition="Alters- und Hinterlassenenversicherung, die staatliche Rente (1. Säule)." /> 5.3%,
    IV 0.7%, EO 0.25%, ALV 1.1%), die <TermTooltip client:load term="Pensionskasse" definition="Die berufliche Vorsorge (2. Säule). Beitragssatz steigt mit dem Alter." />
    und Steuern abgezogen. Bei CHF 85'000 brutto bleiben ca. CHF 65'000 bis 72'000 netto, je nach Kanton.
  </p>

  <Lohnrechner client:load lang="de" />

  <p class="mt-6 text-sm text-[#4B5563] italic">
    Die Berechnungen auf loadouts.info sind unverbindliche Schätzungen und stellen keine Anlage-, Steuer- oder Rechtsberatung dar.
  </p>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Häufige Fragen zum Schweizer Lohn</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <SourceBox client:load federalSources={federalSources} lang="de" />

  <GlossarySection client:load entries={glossaryDE} lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
