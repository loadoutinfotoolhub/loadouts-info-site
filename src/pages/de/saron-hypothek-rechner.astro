---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SaronHypothek from '../../components/calculators/SaronHypothek.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';

const title = 'SARON-Hypothek Rechner 2026: Zinsen, Szenarien, Vergleich | loadouts.info';
const description = 'Berechne deine SARON-Hypothek: Monatsrate, Vergleich mit Festhypothek, Stress-Test. Aktuelle Zinsen, gratis.';

const federalSources = [
  { displayName: 'Schweizerische Nationalbank (SNB)', url: 'https://www.snb.ch/de/der-saron/saron-rate', legalBasis: 'SARON-Referenzzinssatz' },
  { displayName: 'SNB Zinsdaten', url: 'https://data.snb.ch/de/topics/ziredev/chart/zimoma' },
  { displayName: 'FINMA / Schweizerische Bankiervereinigung', url: 'https://www.finma.ch/en/documentation/dossier/dossier-hypothekarmarkt/' },
];

const faqs = [
  { q: 'Was ist SARON?', a: 'SARON steht für Swiss Average Rate Overnight. Es ist der offizielle Schweizer Referenzzinssatz, berechnet von der SNB aus Repo-Transaktionen. SARON-Hypotheken koppeln ihren Zins an diesen Wert plus eine Bankenmarge.' },
  { q: 'SARON oder Festhypothek: Was lohnt sich?', a: 'SARON war in den letzten 15 Jahren meist günstiger. Festhypothek bietet Planungssicherheit. Wer Zinsanstiege verkraften kann, fährt mit SARON oft besser.' },
  { q: 'Was kostet eine SARON-Hypothek von CHF 500\'000?', a: 'Bei SARON 0.3% und Marge 0.8% kostet sie 1.1% p.a. = CHF 5\'500 Zins. Im Vergleich zu einer 10J-Festhypothek (2.0%) sparst du CHF 4\'500 pro Jahr.' },
  { q: 'Kann der SARON negativ werden?', a: 'Ja, historisch war er zeitweise negativ (2015-2022). Meist gilt ein Floor bei 0%, d.h. du zahlst nur die Bankenmarge.' },
  { q: 'Wie oft wird der Zins angepasst?', a: 'Üblicherweise quartalsweise. Der SARON-Compounded-Satz wird alle 3 Monate berechnet und belastet.' },
  { q: 'Wie sichere ich mich gegen Zinsanstieg ab?', a: 'Optionen: Mix aus SARON und Festhypothek, Cap-Vereinbarung mit der Bank, oder Wechsel zu Festhypothek wenn Zinsen steigen.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const appSchema = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'SARON-Hypothek Rechner 2026', url: 'https://loadouts.info/de/saron-hypothek-rechner', applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' }, inLanguage: 'de' };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Start', item: 'https://loadouts.info/de/' }, { '@type': 'ListItem', position: 2, name: 'SARON-Hypothek', item: 'https://loadouts.info/de/saron-hypothek-rechner' }] };

const glossaryDE = [
  { term: 'SARON', definition: 'Swiss Average Rate Overnight. Der offizielle Schweizer Referenzzinssatz, berechnet aus Repo-Transaktionen und täglich von der SNB veröffentlicht.' },
  { term: 'Compounded SARON', definition: 'Der aufgerechnete SARON über einen Zeitraum (z.B. 3 Monate). Wird für die Zinsabrechnung bei SARON-Hypotheken verwendet.' },
  { term: 'Bank-Marge', definition: 'Der Aufschlag, den die Bank auf den SARON berechnet. Typisch 0.6% bis 1.0%. Je besser deine Bonität, desto tiefer die Marge.' },
  { term: 'Festhypothek', definition: 'Hypothek mit fixem Zinssatz über eine feste Laufzeit (z.B. 5 oder 10 Jahre). Bietet Planungssicherheit, ist aber oft teurer als SARON.' },
  { term: 'Geldmarkt-Hypothek', definition: 'Anderer Name für SARON-Hypothek. Der Zinssatz orientiert sich am Geldmarkt statt an langfristigen Kapitalmarktzinsen.' },
  { term: 'Benchmark-Zinssatz', definition: 'Ein Referenzzinssatz, an dem sich variable Hypothekenzinsen orientieren. In der Schweiz ist SARON der offizielle Benchmark.' },
  { term: 'Stress-Test', definition: 'Berechnung, was passiert wenn der Zinssatz stark steigt. Banken prüfen ob du auch bei 5% Zins noch tragbar bist.' },
];
---
<BaseLayout title={title} description={description} lang="de" canonicalSlug="saron-hypothek-rechner" altSlug="saron-mortgage-calculator">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/de/" class="hover:text-[#1E3A8A]">Start</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">SARON-Hypothek</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">SARON-Hypothek Rechner 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    Eine <TermTooltip client:load term="SARON-Hypothek" definition="Variable Hypothek, deren Zinssatz an den Swiss Average Rate Overnight gekoppelt ist." />
    ist eine variable Hypothek, deren Zinssatz an den <TermTooltip client:load term="SARON" definition="Swiss Average Rate Overnight, der offizielle Schweizer Referenzzinssatz der SNB." />
    gekoppelt ist. Bei einem aktuellen SARON von ca. 0.2-0.5% und einer
    <TermTooltip client:load term="Bank-Marge" definition="Aufschlag der Bank auf den SARON, typisch 0.6-1.0%." /> von 0.6-1.0%
    liegen die Gesamtkosten bei etwa 1-1.5% pro Jahr.
  </p>

  <SaronHypothek client:load lang="de" />

  <p class="mt-6 text-sm text-[#4B5563] italic">
    Die Berechnungen auf loadouts.info sind unverbindliche Schätzungen und stellen keine Anlage-, Steuer- oder Rechtsberatung dar.
  </p>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Häufige Fragen zur SARON-Hypothek</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <SourceBox client:load federalSources={federalSources} lang="de" />
  <GlossarySection client:load entries={glossaryDE} lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
