---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prozentrechner from '../../components/calculators/Prozentrechner.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';

const title = 'Prozentrechner: Prozent berechnen, Anteil, Veraenderung | loadouts.info';
const description = 'Berechne Prozente schnell und einfach: Prozentwert, Grundwert, Prozentsatz, prozentuale Veraenderung. Gratis, sofort, ohne Anmeldung.';

const faqs = [
  { q: 'Wie berechne ich einen Prozentsatz?', a: 'Prozentsatz = (Prozentwert / Grundwert) x 100. Beispiel: 15 von 200 sind 7.5%. Gib einfach die beiden Werte in unseren Rechner ein.' },
  { q: 'Wie berechne ich die prozentuale Veraenderung?', a: 'Prozentuale Veraenderung = ((Neuer Wert - Alter Wert) / Alter Wert) x 100. Ein positives Ergebnis zeigt eine Zunahme, ein negatives eine Abnahme an.' },
  { q: 'Was ist der Unterschied zwischen Prozentpunkt und Prozent?', a: 'Wenn ein Zinssatz von 2% auf 3% steigt, ist das eine Erhoehung um 1 Prozentpunkt, aber eine Zunahme um 50%. Prozentpunkte messen die absolute Differenz, Prozent die relative Veraenderung.' },
  { q: 'Wie berechne ich einen Rabatt in Prozent?', a: 'Rabatt in CHF = Originalpreis x (Rabatt in % / 100). Endpreis = Originalpreis - Rabatt. Bei 20% Rabatt auf CHF 150: Rabatt = CHF 30, Endpreis = CHF 120.' },
  { q: 'Wie rechne ich Brutto in Netto um?', a: 'Netto = Brutto / (1 + Steuersatz). Fuer die Schweizer MwSt mit 8.1% Normalsatz: Netto = Brutto / 1.081. Fuer genauere MwSt-Berechnungen nutze unseren MwSt-Rechner.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Prozentrechner',
  url: 'https://loadouts.info/de/prozentrechner',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'de',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: 'https://loadouts.info/de/' },
    { '@type': 'ListItem', position: 2, name: 'Prozentrechner', item: 'https://loadouts.info/de/prozentrechner' },
  ],
};

const glossaryDE = [
  { term: 'Prozentsatz', definition: 'Die Verhaeltniszahl, ausgedrueckt in Hundertsteln. 25% bedeutet 25 von 100 oder ein Viertel des Grundwerts.' },
  { term: 'Grundwert', definition: 'Der Ausgangswert (100%), auf den sich die Prozentrechnung bezieht. Beispiel: Bei "20% von 500" ist 500 der Grundwert.' },
  { term: 'Prozentwert', definition: 'Das Ergebnis der Prozentrechnung in absoluten Zahlen. Beispiel: 20% von 500 ergibt den Prozentwert 100.' },
  { term: 'Prozentuale Veraenderung', definition: 'Die relative Aenderung zwischen einem alten und einem neuen Wert, ausgedrueckt in Prozent. Zeigt Wachstum (positiv) oder Rueckgang (negativ) an.' },
  { term: 'Prozentpunkt', definition: 'Die absolute Differenz zwischen zwei Prozentwerten. Wenn ein Satz von 5% auf 8% steigt, sind das 3 Prozentpunkte, aber eine Zunahme um 60%.' },
];
---
<BaseLayout title={title} description={description} lang="de" canonicalSlug="prozentrechner" altSlug="percentage-calculator">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/de/" class="hover:text-[#1E3A8A]">Start</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Prozentrechner</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Prozentrechner</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    Der Prozentrechner loest alle gaengigen Aufgaben rund um
    <TermTooltip client:load term="Prozentsatz" definition="Die Verhaeltniszahl in Hundertsteln. 25% bedeutet 25 von 100." />,
    <TermTooltip client:load term="Grundwert" definition="Der Ausgangswert (100%), auf den sich die Berechnung bezieht." /> und
    <TermTooltip client:load term="Prozentwert" definition="Das Ergebnis der Prozentrechnung in absoluten Zahlen." />.
    Berechne auch die prozentuale Veraenderung zwischen zwei Werten.
  </p>

  <Prozentrechner client:load lang="de" />

  <div class="mt-12 bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-[#4B5563]">
    Die Berechnungen auf loadouts.info sind unverbindliche Schaetzungen und stellen keine Anlage-, Steuer- oder Rechtsberatung dar.
  </div>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Haeufige Fragen zur Prozentrechnung</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <GlossarySection client:load entries={glossaryDE} lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
