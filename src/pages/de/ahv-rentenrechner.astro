---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AhvRente from '../../components/calculators/AhvRente.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';
import { CH2026, CH2026Sourced } from '../../lib/ch-constants';

const fmtCHF = (v: number) => new Intl.NumberFormat('de-CH').format(v);

const title = 'AHV-Rentenrechner 2026: Rente berechnen | loadouts.info';
const description = `Berechne deine AHV-Rente 2026. Maximalrente CHF ${fmtCHF(CH2026.ahvRenten.maxEinzelMonat)}/Mt., Minimalrente CHF ${fmtCHF(CH2026.ahvRenten.minEinzelMonat)}/Mt. Gratis, ohne Anmeldung.`;

const federalSources = [
  { displayName: CH2026Sourced.ahvRenten.maxEinzelMonat.source.displayName, url: CH2026Sourced.ahvRenten.maxEinzelMonat.source.url, legalBasis: CH2026Sourced.ahvRenten.maxEinzelMonat.source.legalBasis },
  { displayName: 'Fedlex - AHVG', url: 'https://www.fedlex.admin.ch/eli/cc/1952/1021_1046_1050/de' },
  { displayName: 'Informationsstelle AHV/IV', url: 'https://www.ahv-iv.ch/de/Sozialversicherungen/Alters-und-Hinterlassenenversicherung-AHV/Altersrenten' },
];

const faqs = [
  { q: 'Wie hoch ist die maximale AHV-Rente 2026?', a: `Die maximale Einzelrente betraegt CHF ${fmtCHF(CH2026.ahvRenten.maxEinzelMonat)} pro Monat. Ehepaare erhalten zusammen maximal CHF ${fmtCHF(CH2026.ahvRenten.maxEhepaarMonat)} pro Monat (Plafonierung auf 150% der Maximalrente).` },
  { q: 'Wie hoch ist die minimale AHV-Rente?', a: `Die Minimalrente betraegt CHF ${fmtCHF(CH2026.ahvRenten.minEinzelMonat)} pro Monat. Sie wird bei lueckenhafter Beitragszeit und tiefem durchschnittlichem Jahreseinkommen ausbezahlt.` },
  { q: 'Was bestimmt die Hoehe meiner AHV-Rente?', a: 'Drei Faktoren: die Beitragsdauer (Beitragsluecken reduzieren die Rente), das durchschnittliche Jahreseinkommen waehrend der Erwerbszeit und allfaellige Erziehungs- oder Betreuungsgutschriften.' },
  { q: 'Wann erhalte ich die volle AHV-Rente?', a: 'Die volle Rente erhaeltst du bei lueckenloser Beitragsdauer ab Alter 21 bis zum Referenzalter 65. Jedes fehlende Beitragsjahr fuehrt zu einer Kuerzung von ca. 1/44 der Vollrente.' },
  { q: 'Kann ich die AHV-Rente vorbeziehen oder aufschieben?', a: 'Vorbezug ist ab 2 Jahre vor dem Referenzalter moeglich, mit einer Kuerzung von 6.8% pro Vorbezugsjahr. Aufschub ist bis 5 Jahre nach dem Referenzalter moeglich und bringt einen Zuschlag von 5.2% bis 31.5%.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'AHV-Rentenrechner 2026',
  url: 'https://loadouts.info/de/ahv-rentenrechner',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'de',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: 'https://loadouts.info/de/' },
    { '@type': 'ListItem', position: 2, name: 'AHV-Rentenrechner', item: 'https://loadouts.info/de/ahv-rentenrechner' },
  ],
};

const glossaryDE = [
  { term: 'AHV (Alters- und Hinterlassenenversicherung)', definition: 'Die 1. Saeule der Schweizer Altersvorsorge. Obligatorisch fuer alle Erwerbstaetigen. Finanziert durch Lohnbeitraege von Arbeitnehmer und Arbeitgeber.' },
  { term: 'Referenzalter', definition: 'Das ordentliche Rentenalter in der Schweiz, aktuell 65 Jahre fuer Maenner und Frauen (nach Reform AHV 21). Ab diesem Alter hast du Anspruch auf die volle AHV-Rente.' },
  { term: 'Beitragsdauer', definition: 'Die Anzahl Jahre, in denen du AHV-Beitraege geleistet hast. Eine lueckenlose Beitragsdauer ab Alter 21 bis zum Referenzalter ergibt die volle Rente.' },
  { term: 'Plafonierung', definition: 'Begrenzung der Ehepaarrente auf 150% der Maximalrente einer Einzelperson. Betrifft Ehepaare, bei denen beide Partner eine AHV-Rente beziehen.' },
  { term: 'Erziehungsgutschriften', definition: 'Fiktive Einkommen, die fuer Jahre der Kindererziehung zum durchschnittlichen Jahreseinkommen addiert werden. Erhoehen die AHV-Rente.' },
];
---
<BaseLayout title={title} description={description} lang="de" canonicalSlug="ahv-rentenrechner" altSlug="ahv-pension-calculator">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/de/" class="hover:text-[#1E3A8A]">Start</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">AHV-Rentenrechner</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">AHV-Rentenrechner 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    Die <TermTooltip client:load term="AHV" definition="Alters- und Hinterlassenenversicherung, die 1. Saeule der Schweizer Altersvorsorge. Obligatorisch fuer alle Erwerbstaetigen." />
    ist die Grundlage der Schweizer Altersvorsorge. 2026 betraegt die Maximalrente
    <strong>CHF {fmtCHF(CH2026.ahvRenten.maxEinzelMonat)}</strong> pro Monat, die
    <TermTooltip client:load term="Minimalrente" definition={`Die tiefste moegliche AHV-Rente von CHF ${fmtCHF(CH2026.ahvRenten.minEinzelMonat)} pro Monat bei lueckenhafter Beitragszeit.`} />
    liegt bei <strong>CHF {fmtCHF(CH2026.ahvRenten.minEinzelMonat)}</strong>. Berechne hier deine voraussichtliche Rente.
  </p>

  <AhvRente client:load lang="de" maxEinzelMonat={CH2026.ahvRenten.maxEinzelMonat} minEinzelMonat={CH2026.ahvRenten.minEinzelMonat} maxEhepaarMonat={CH2026.ahvRenten.maxEhepaarMonat} />

  <div class="mt-12 bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-[#4B5563]">
    Die Berechnungen auf loadouts.info sind unverbindliche Schaetzungen und stellen keine Anlage-, Steuer- oder Rechtsberatung dar.
  </div>

  <SourceBox client:load federalSources={federalSources} lang="de" />

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Haeufige Fragen zur AHV-Rente</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <GlossarySection client:load entries={glossaryDE} lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
