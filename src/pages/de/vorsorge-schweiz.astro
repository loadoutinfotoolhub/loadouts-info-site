---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import { CH2026 } from '../../lib/ch-constants';

const title = 'Vorsorge Schweiz: 3-Säulen-System einfach erklärt 2026 | loadouts.info';
const description = 'Kompletter Leitfaden zur Schweizer Altersvorsorge 2026. AHV, Pensionskasse, Säule 3a. Mit Rechnern, Beispielen und allen aktuellen Zahlen.';

const fmt = (n: number) => new Intl.NumberFormat('de-CH').format(n);

const faqs = [
  { q: 'Reichen AHV und Pensionskasse zum Leben?', a: `Die AHV-Maximalrente liegt 2026 bei CHF ${fmt(CH2026.ahvRenten.maxEinzelMonat)} pro Monat. Zusammen mit der Pensionskasse sollen 60% des letzten Lohns gedeckt sein. Bei einem Medianlohn von CHF 85'000 ergeben sich ca. CHF 4'000 bis 5'000 monatlich aus den beiden ersten Säulen. Für viele reicht das nicht, um den Lebensstandard zu halten.` },
  { q: 'Wann sollte ich mit der 3. Säule beginnen?', a: `So früh wie möglich. Jedes Jahr, in dem du den Maximalbetrag von CHF ${fmt(CH2026.saeule3a.maxMitPK)} einzahlst, spart dir Steuern und dein Geld profitiert vom Zinseszinseffekt. Wer mit 25 beginnt, hat 40 Einzahlungsjahre bis zur Pensionierung.` },
  { q: 'Was passiert mit meiner Vorsorge wenn ich auswandere?', a: 'Die AHV-Beitragsjahre bleiben erhalten und du kannst die Rente ins Ausland beziehen. Die Pensionskasse wird als Freizügigkeitsleistung ausbezahlt oder gesperrt. Säule-3a-Guthaben kannst du bei definitiver Ausreise vorbeziehen.' },
  { q: 'Wie viel sollte ich monatlich in die 3a einzahlen?', a: `Mit Pensionskasse optimal CHF 604.85 pro Monat (= ${fmt(CH2026.saeule3a.maxMitPK)} / 12). Monatlicher Dauerauftrag ab Januar maximiert die Rendite. Alternativ eine Einmalzahlung im Januar.` },
  { q: 'Lohnt sich ein PK-Einkauf für mich?', a: 'Ja, wenn du Lücken in der Pensionskasse hast und einen hohen Grenzsteuersatz. Der Einkauf ist voll steuerabzugsfähig. Achtung: 3-Jahres-Sperrfrist vor Kapitalbezug. Bei geplanter Frühpensionierung rechtzeitig einzahlen.' },
  { q: 'Rente oder Kapital: Was ist besser?', a: 'Kommt auf deine Situation an. Rente bietet Sicherheit und lebenslange Zahlung. Kapital bietet Flexibilität und kann vererbt werden. Viele wählen einen Mix. Die Steuerlast beim Kapitalbezug ist oft tiefer als die kumulative Rentensteuer.' },
  { q: 'Was ändert sich mit AHV 21 für mich?', a: 'Das Referenzalter für Frauen steigt schrittweise von 64 auf 65 (bis 2028). Flexibler Rentenbezug zwischen 63 und 70 für alle. Wer länger arbeitet und Beiträge zahlt, erhält einen Zuschlag.' },
  { q: 'Kann ich mit 3a meine Hypothek amortisieren?', a: 'Ja, die indirekte Amortisation über die Säule 3a ist in der Schweiz sehr beliebt. Du zahlst in die 3a statt direkt an die Bank, sparst Steuern und amortisierst bei Bezug. Bedingung: selbstbewohntes Wohneigentum.' },
  { q: 'Bin ich als Selbständige/r bei der PK versichert?', a: 'Nicht automatisch. Selbständigerwerbende können sich freiwillig bei der BVG-Auffangeinrichtung oder einer Verbandsvorsorge versichern. Ohne PK steigt der Säule-3a-Maximalbetrag auf 20% des Nettoeinkommens (max CHF 36\'288).' },
  { q: 'Wann muss ich die AHV-Rente beantragen?', a: 'Die AHV-Rente wird nicht automatisch ausbezahlt. Du musst sie 3 bis 4 Monate vor dem Referenzalter bei deiner Ausgleichskasse beantragen. Das Antragsformular findest du auf ahv-iv.ch.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const articleSchema = { '@context': 'https://schema.org', '@type': 'Article', headline: title, datePublished: '2026-04-13', dateModified: '2026-04-13', author: { '@type': 'Organization', name: 'loadouts.info' }, publisher: { '@type': 'Organization', name: 'loadouts.info' } };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Start', item: 'https://loadouts.info/de/' }, { '@type': 'ListItem', position: 2, name: 'Vorsorge Schweiz', item: 'https://loadouts.info/de/vorsorge-schweiz' }] };

const federalSources = [
  { displayName: 'Bundesamt für Sozialversicherungen (BSV)', url: 'https://www.bsv.admin.ch', legalBasis: 'AHVG, BVG, BVV 3' },
  { displayName: 'Informationsstelle AHV/IV', url: 'https://www.ahv-iv.ch/de/Sozialversicherungen' },
  { displayName: 'Fedlex: Bundesverfassung Art. 111-113', url: 'https://www.fedlex.admin.ch/eli/cc/1999/404/de' },
  { displayName: 'Fedlex: BVG (Pensionskassengesetz)', url: 'https://www.fedlex.admin.ch/eli/cc/1983/797_797_797/de' },
  { displayName: 'Fedlex: BVV 3 (Säule-3a-Verordnung)', url: 'https://www.fedlex.admin.ch/eli/cc/1985/2_2_2/de' },
];

const glossary = [
  { term: '3-Säulen-System', definition: 'Das Schweizer Vorsorgesystem bestehend aus staatlicher AHV (1. Säule), beruflicher Pensionskasse (2. Säule) und freiwilliger privater Vorsorge (3. Säule).' },
  { term: 'AHV', definition: 'Alters- und Hinterlassenenversicherung. Die staatliche Rente, finanziert im Umlageverfahren. Obligatorisch für alle in der Schweiz.' },
  { term: 'BVG / Pensionskasse', definition: 'Berufliche Vorsorge (2. Säule). Obligatorisch für Angestellte ab einem bestimmten Lohn. Arbeitgeber und Arbeitnehmer zahlen gemeinsam ein.' },
  { term: 'Säule 3a', definition: 'Gebundene private Vorsorge mit Steuerabzug. Maximalbetrag 2026: CHF 7\'258 (mit PK) oder CHF 36\'288 (ohne PK).' },
  { term: 'Säule 3b', definition: 'Freie private Vorsorge ohne Begrenzung und ohne Steuerabzug. Zum Beispiel Sparkonto, Wertschriften, Lebensversicherung.' },
  { term: 'Umlageverfahren', definition: 'Finanzierungsmodell, bei dem die heutigen Erwerbstätigen die heutigen Renten finanzieren. So funktioniert die AHV.' },
  { term: 'Kapitaldeckungsverfahren', definition: 'Finanzierungsmodell, bei dem jede Person für sich selbst spart. So funktioniert die Pensionskasse.' },
  { term: 'Koordinationsabzug', definition: 'Betrag, der vor der BVG-Berechnung vom Lohn abgezogen wird (2026: CHF 26\'460), da die AHV bereits einen Teil abdeckt.' },
  { term: 'Umwandlungssatz', definition: 'Prozentsatz, mit dem das PK-Alterskapital in eine jährliche Rente umgewandelt wird. BVG-Minimum: 6.8%.' },
  { term: 'Referenzalter', definition: 'Das Alter, ab dem du Anspruch auf eine ungekürzte AHV-Rente hast. Mit AHV 21: 65 Jahre für Frauen und Männer.' },
  { term: 'Freizügigkeit', definition: 'Beim Stellenwechsel wird dein PK-Guthaben auf ein Freizügigkeitskonto übertragen oder an die neue PK überwiesen.' },
  { term: 'Vorsorgelücke', definition: 'Die Differenz zwischen deinem letzten Lohn und den erwarteten Renten aus AHV + PK. Muss mit 3. Säule oder Ersparnissen geschlossen werden.' },
];
---
<BaseLayout title={title} description={description} lang="de" canonicalSlug="vorsorge-schweiz" altSlug="pension-switzerland">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/de/" class="hover:text-[#1E3A8A]">Start</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Vorsorge Schweiz</span>
  </nav>

  <article class="max-w-prose">
    <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-6 leading-tight">Vorsorge Schweiz: Der komplette Leitfaden 2026</h1>

    <p class="text-lg text-[#4B5563] mb-6 leading-relaxed">
      Das Schweizer Vorsorgesystem basiert seit 1972 auf drei Säulen: der staatlichen AHV (1. Säule) für die Existenzsicherung, der beruflichen BVG-Pensionskasse (2. Säule) zur Erhaltung des Lebensstandards und der freiwilligen privaten Vorsorge (3. Säule). 2026 liegt die maximale AHV-Einzelrente bei CHF {fmt(CH2026.ahvRenten.maxEinzelMonat)} monatlich, der Säule-3a-Maximalbetrag mit Pensionskasse bei CHF {fmt(CH2026.saeule3a.maxMitPK)}.
    </p>

    <!-- H2 1: 3-Säulen-System -->
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">Das 3-Säulen-System auf einen Blick</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Das 3-Säulen-System ist seit 1972 in der Bundesverfassung verankert (Art. 111 BV). Es verteilt die Altersvorsorge auf drei Träger: den Staat, den Arbeitgeber und die Eigenverantwortung. Ziel ist, dass AHV und Pensionskasse zusammen 60% des letzten Lohns ersetzen. Die 3. Säule schliesst die verbleibende Lücke.
    </p>
    <div class="bg-white rounded-lg border border-gray-200 p-4 mb-6 overflow-x-auto">
      <table class="w-full text-sm">
        <thead><tr class="border-b"><th class="text-left py-2 text-[#1E3A8A]">Säule</th><th class="text-left py-2 text-[#1E3A8A]">Typ</th><th class="text-left py-2 text-[#1E3A8A]">Obligatorisch?</th><th class="text-left py-2 text-[#1E3A8A]">Finanzierung</th></tr></thead>
        <tbody>
          <tr class="border-b"><td class="py-2">1. Säule (AHV)</td><td>Staatlich</td><td>Ja</td><td>Umlageverfahren</td></tr>
          <tr class="border-b"><td class="py-2">2. Säule (BVG)</td><td>Beruflich</td><td>Ab CHF {fmt(CH2026.bvg.eintrittsschwelle)} Lohn</td><td>Kapitaldeckung</td></tr>
          <tr><td class="py-2">3. Säule (3a/3b)</td><td>Privat</td><td>Freiwillig</td><td>Eigenverantwortung</td></tr>
        </tbody>
      </table>
    </div>

    <!-- H2 2: AHV -->
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">1. Säule: AHV und IV (Staatliche Vorsorge)</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Die AHV (Alters- und Hinterlassenenversicherung) deckt die Existenzsicherung im Alter. Sie ist obligatorisch für alle in der Schweiz wohnhaften oder tätigen Personen ab dem 18. Altersjahr. 2026 liegt die minimale AHV-Einzelrente bei CHF {fmt(CH2026.ahvRenten.minEinzelMonat)} monatlich, die maximale bei CHF {fmt(CH2026.ahvRenten.maxEinzelMonat)}. Ehepaare erhalten maximal CHF {fmt(CH2026.ahvRenten.maxEhepaarMonat)} (150% der Maximalrente).
    </p>
    <h3 class="text-xl font-semibold text-[#1E3A8A] mt-6 mb-3">Wer ist versichert?</h3>
    <p class="text-[#4B5563] mb-4 leading-relaxed">Alle Personen, die in der Schweiz wohnen oder arbeiten. Die Beitragspflicht beginnt am 1. Januar nach dem 17. Geburtstag für Erwerbstätige, am 1. Januar nach dem 20. Geburtstag für Nichterwerbstätige.</p>

    <h3 class="text-xl font-semibold text-[#1E3A8A] mt-6 mb-3">Beitragssätze</h3>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      AHV: {(CH2026.sozialversicherung.ahv * 200).toFixed(1)}% der Lohnsumme ({(CH2026.sozialversicherung.ahv * 100).toFixed(1)}% Arbeitnehmer, {(CH2026.sozialversicherung.ahv * 100).toFixed(1)}% Arbeitgeber). Dazu kommen IV ({(CH2026.sozialversicherung.iv * 200).toFixed(1)}%) und EO ({(CH2026.sozialversicherung.eo * 200).toFixed(2)}%). Die Beiträge werden direkt vom Lohn abgezogen. <a href="/de/lohnrechner" class="text-[#1E3A8A] underline">Unser Lohnrechner</a> zeigt dir alle Abzüge.
    </p>

    <h3 class="text-xl font-semibold text-[#1E3A8A] mt-6 mb-3">AHV 21: Was ändert sich?</h3>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Das Referenzalter für Frauen steigt schrittweise von 64 auf 65 Jahre (bis 2028). Flexibler Rentenbezug zwischen 63 und 70 wird möglich. Für 44 volle Beitragsjahre erhältst du die maximale Rente.
    </p>

    <!-- H2 3: Pensionskasse -->
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">2. Säule: Berufliche Vorsorge (BVG / Pensionskasse)</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Die Pensionskasse ist obligatorisch für alle Angestellten mit Jahreslohn über CHF {fmt(CH2026.bvg.eintrittsschwelle)} (BVG-Eintrittsschwelle 2026). Sie ergänzt die AHV und soll zusammen mit ihr etwa 60% des letzten Einkommens ersetzen. Im Gegensatz zur AHV basiert sie auf dem Kapitaldeckungsverfahren: du sparst für dich selbst.
    </p>

    <h3 class="text-xl font-semibold text-[#1E3A8A] mt-6 mb-3">Beitragssätze nach Alter</h3>
    <p class="text-[#4B5563] mb-2 leading-relaxed">Die Sparbeiträge steigen mit dem Alter. Die Gesamtbeiträge (Arbeitnehmer + Arbeitgeber) betragen:</p>
    <ul class="list-disc pl-6 text-[#4B5563] mb-4 space-y-1">
      <li>25 bis 34 Jahre: {(CH2026.bvg.beitragssaetze['25_34'] * 100).toFixed(0)}%</li>
      <li>35 bis 44 Jahre: {(CH2026.bvg.beitragssaetze['35_44'] * 100).toFixed(0)}%</li>
      <li>45 bis 54 Jahre: {(CH2026.bvg.beitragssaetze['45_54'] * 100).toFixed(0)}%</li>
      <li>55 bis 65 Jahre: {(CH2026.bvg.beitragssaetze['55_65'] * 100).toFixed(0)}%</li>
    </ul>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Der Koordinationsabzug von CHF {fmt(CH2026.bvg.koordinationsabzug)} wird vom Lohn abgezogen, bevor der BVG-Beitrag berechnet wird. Nur der Lohn zwischen CHF {fmt(CH2026.bvg.koordinationsabzug)} und CHF {fmt(CH2026.bvg.maxVersLohn)} ist obligatorisch versichert. Der Arbeitgeber muss mindestens 50% der Beiträge tragen.
    </p>

    <h3 class="text-xl font-semibold text-[#1E3A8A] mt-6 mb-3">Umwandlungssatz und Rente</h3>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Der BVG-Mindest-Umwandlungssatz liegt bei {(CH2026.bvg.umwandlungssatz * 100).toFixed(1)}%. Das bedeutet: Bei einem Alterskapital von CHF 500'000 erhältst du mindestens CHF {fmt(500000 * CH2026.bvg.umwandlungssatz)} Rente pro Jahr. Viele Pensionskassen bieten überobligatorisch höhere Leistungen.
    </p>

    <!-- H2 4: 3. Säule -->
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">3. Säule: Private Vorsorge (3a und 3b)</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Die 3. Säule ist freiwillig und schliesst die Lücke zwischen deinem letzten Lohn und den Renten aus AHV und Pensionskasse. Die Säule 3a (gebunden) bietet massive Steuervorteile: 2026 darfst du maximal CHF {fmt(CH2026.saeule3a.maxMitPK)} einzahlen, wenn du einer Pensionskasse angehörst. Ohne Pensionskasse sind es bis zu 20% des Nettoeinkommens, maximal CHF {fmt(CH2026.saeule3a.maxOhnePK)}.
    </p>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Neu seit 2026: Nachträgliche Einzahlungen sind erstmals möglich. Du kannst Lücken ab 2025 rückwirkend für bis zu 10 Jahre schliessen, sofern du den Maximalbetrag des laufenden Jahres bereits einbezahlt hast.
    </p>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      <a href="/de/saeule-3a-rechner" class="text-[#1E3A8A] underline font-medium">Berechne jetzt deinen Säule-3a-Maximalbetrag und die Steuerersparnis</a>.
    </p>

    <!-- H2 5: Vorsorgelücken -->
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">Vorsorgelücken identifizieren und schliessen</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Eine Vorsorgelücke entsteht, wenn deine Renten aus AHV und Pensionskasse weniger als 60 bis 70% deines letzten Lohns erreichen. Typische Ursachen: Teilzeitarbeit, Erwerbsunterbrüche, Auslandaufenthalte, tiefe PK-Beiträge, Frühpensionierung.
    </p>
    <p class="text-[#4B5563] mb-4 leading-relaxed"><strong>5 Strategien gegen Vorsorgelücken:</strong></p>
    <ol class="list-decimal pl-6 text-[#4B5563] mb-4 space-y-1">
      <li>Säule 3a jedes Jahr voll ausschöpfen</li>
      <li>Freiwillige PK-Einkäufe tätigen (steuerabzugsfähig)</li>
      <li>Länger arbeiten (AHV-Aufschub bringt Zuschlag)</li>
      <li>Frei sparen und investieren (Säule 3b)</li>
      <li>Wohneigentum als Teil der Altersvorsorge nutzen</li>
    </ol>

    <!-- H2 6: Steuern -->
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">Vorsorge und Steuern optimieren</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Vorsorge und Steuern sind in der Schweiz eng verknüpft. Einzahlungen in die Säule 3a und PK-Einkäufe reduzieren dein steuerbares Einkommen direkt. Bei der Auszahlung wird das Kapital reduziert und separat besteuert (Kapitalbezugssteuer). Die Steuer variiert stark nach Kanton.
    </p>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Tipp: Mehrere 3a-Konten eröffnen und gestaffelt beziehen. So verteilst du die Kapitalbezugssteuer auf mehrere Jahre und senkst die Progression. <a href="/de/lohnrechner" class="text-[#1E3A8A] underline">Unser Lohnrechner zeigt deinen Grenzsteuersatz</a>, der bestimmt wie viel du pro 3a-Franken sparst.
    </p>

    <!-- H2 7: FAQ -->
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-6">Häufige Fragen zur Schweizer Vorsorge</h2>
    <div class="space-y-4">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>

    <!-- H2 8: Nächste Schritte -->
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">Deine nächsten Schritte</h2>
    <div class="grid sm:grid-cols-2 gap-3 mb-8">
      <a href="/de/saeule-3a-rechner" class="block bg-[#059669] text-white rounded-lg p-4 hover:bg-[#047857] transition-colors font-medium text-center">Säule 3a Rechner starten</a>
      <a href="/de/lohnrechner" class="block bg-[#1E3A8A] text-white rounded-lg p-4 hover:bg-[#1E3070] transition-colors font-medium text-center">Lohn und Abzüge berechnen</a>
      <a href="/de/hypothek-tragbarkeit" class="block bg-white border border-[#1E3A8A] text-[#1E3A8A] rounded-lg p-4 hover:bg-blue-50 transition-colors font-medium text-center">Hypothek-Tragbarkeit prüfen</a>
      <a href="/de/saron-hypothek-rechner" class="block bg-white border border-[#1E3A8A] text-[#1E3A8A] rounded-lg p-4 hover:bg-blue-50 transition-colors font-medium text-center">SARON-Hypothek berechnen</a>
    </div>
  </article>

  <SourceBox client:load federalSources={federalSources} lang="de" />
  <GlossarySection client:load entries={glossary} lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
