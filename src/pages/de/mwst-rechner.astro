---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MwstRechner from '../../components/calculators/MwstRechner.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';
import { CH2026, CH2026Sourced } from '../../lib/ch-constants';

const title = 'MwSt-Rechner Schweiz 2026: Normalsatz, reduziert, Beherbergung | loadouts.info';
const description = 'Berechne die Schweizer Mehrwertsteuer 2026: Normalsatz 8.1%, reduzierter Satz 2.6%, Beherbergung 3.8%. Netto/Brutto sofort umrechnen.';

const normalPct = (CH2026.mwst.normal * 100).toFixed(1);
const reduzPct = (CH2026.mwst.reduziert * 100).toFixed(1);
const beherPct = (CH2026.mwst.beherbergung * 100).toFixed(1);

const federalSources = [
  { displayName: CH2026Sourced.mwst.normal.source.displayName, url: CH2026Sourced.mwst.normal.source.url, legalBasis: CH2026Sourced.mwst.normal.source.legalBasis },
  { displayName: 'Fedlex - Mehrwertsteuergesetz MWSTG', url: 'https://www.fedlex.admin.ch/eli/cc/2009/615/de' },
];

const faqs = [
  { q: 'Wie hoch ist die MwSt in der Schweiz 2026?', a: `Der Normalsatz betraegt ${normalPct}%, der reduzierte Satz ${reduzPct}% und der Sondersatz fuer Beherbergung ${beherPct}%. Diese Saetze gelten seit dem 01.01.2024.` },
  { q: 'Welche Waren haben den reduzierten MwSt-Satz?', a: 'Lebensmittel (ausser Alkohol und Restaurant), Medikamente, Zeitungen, Zeitschriften und Buecher fallen unter den reduzierten Satz. Auch Wasser aus der Leitung ist reduziert besteuert.' },
  { q: 'Wie rechne ich Brutto in Netto um?', a: `Nettobetrag = Bruttobetrag / (1 + MwSt-Satz). Bei ${normalPct}% Normalsatz: Netto = Brutto / 1.081. Unser Rechner erledigt die Umrechnung in beide Richtungen sofort.` },
  { q: 'Wer muss MwSt abrechnen?', a: 'Unternehmen mit einem Jahresumsatz ab CHF 100\'000 aus steuerbaren Leistungen sind MwSt-pflichtig. Freiwillige Unterstellung ist moeglich und kann sich bei hohem Vorsteuerabzug lohnen.' },
  { q: 'Was ist der Unterschied zur deutschen MwSt?', a: `Die Schweiz hat mit ${normalPct}% einen der tiefsten Normalsaetze Europas. Deutschland erhebt 19% (Normalsatz) bzw. 7% (ermaessigt). In der Schweiz gibt es zusaetzlich den Sondersatz fuer Beherbergung.` },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'MwSt-Rechner Schweiz 2026',
  url: 'https://loadouts.info/de/mwst-rechner',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'de',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: 'https://loadouts.info/de/' },
    { '@type': 'ListItem', position: 2, name: 'MwSt-Rechner', item: 'https://loadouts.info/de/mwst-rechner' },
  ],
};

const glossaryDE = [
  { term: 'Mehrwertsteuer (MwSt)', definition: 'Indirekte Verbrauchssteuer auf Waren und Dienstleistungen. Wird vom Endkonsumenten getragen, aber vom Unternehmen an die ESTV abgefuehrt.' },
  { term: 'Normalsatz', definition: `Der Standard-MwSt-Satz in der Schweiz, aktuell ${normalPct}%. Gilt fuer die meisten Waren und Dienstleistungen.` },
  { term: 'Reduzierter Satz', definition: `Der tiefere MwSt-Satz von ${reduzPct}%. Gilt fuer Lebensmittel, Medikamente, Buecher und Zeitungen.` },
  { term: 'Sondersatz Beherbergung', definition: `Spezialsatz von ${beherPct}% fuer Uebernachtungen in Hotels, Pensionen und aehnlichen Betrieben.` },
  { term: 'Vorsteuerabzug', definition: 'MwSt-pflichtige Unternehmen duerfen die auf ihren Einkaufen bezahlte MwSt (Vorsteuer) von ihrer geschuldeten MwSt abziehen.' },
];
---
<BaseLayout title={title} description={description} lang="de" canonicalSlug="mwst-rechner" altSlug="vat-calculator">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/de/" class="hover:text-[#1E3A8A]">Start</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">MwSt-Rechner</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">MwSt-Rechner Schweiz 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    Die <TermTooltip client:load term="Mehrwertsteuer (MwSt)" definition="Indirekte Verbrauchssteuer auf Waren und Dienstleistungen. Wird vom Endkonsumenten getragen." />
    in der Schweiz kennt drei Saetze: <strong>{normalPct}%</strong> Normalsatz,
    <strong>{reduzPct}%</strong> <TermTooltip client:load term="reduzierter Satz" definition={`Der tiefere MwSt-Satz von ${reduzPct}% fuer Lebensmittel, Medikamente, Buecher und Zeitungen.`} />
    und <strong>{beherPct}%</strong> fuer Beherbergung. Rechne hier Netto- und Bruttobetraege sofort um.
  </p>

  <MwstRechner client:load lang="de" normal={CH2026.mwst.normal} reduziert={CH2026.mwst.reduziert} beherbergung={CH2026.mwst.beherbergung} />

  <div class="mt-12 bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-[#4B5563]">
    Die Berechnungen auf loadouts.info sind unverbindliche Schaetzungen und stellen keine Anlage-, Steuer- oder Rechtsberatung dar.
  </div>

  <SourceBox client:load federalSources={federalSources} lang="de" />

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Haeufige Fragen zur Mehrwertsteuer</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <GlossarySection client:load entries={glossaryDE} lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
