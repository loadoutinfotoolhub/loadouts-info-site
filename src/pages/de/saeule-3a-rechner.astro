---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Saeule3a from '../../components/calculators/Saeule3a.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import { CH2026, CH2026Sourced } from '../../lib/ch-constants';

const title = 'Saeule 3a Rechner 2026: Maximalbetrag & Steuerersparnis | loadouts.info';
const description = 'Berechne sofort deinen Saeule 3a Maximalbetrag und die Steuerersparnis fuer 2026. Gratis, ohne Anmeldung. Alle Kantone.';

const federalSources = [
  { displayName: CH2026Sourced.saeule3a.maxMitPK.source.displayName, url: CH2026Sourced.saeule3a.maxMitPK.source.url, legalBasis: CH2026Sourced.saeule3a.maxMitPK.source.legalBasis },
  { displayName: 'Fedlex - BVV 3 (Verordnung)', url: 'https://www.fedlex.admin.ch/eli/cc/1985/2_2_2/de' },
  { displayName: 'Informationsstelle AHV/IV', url: 'https://www.ahv-iv.ch/de/Sozialversicherungen' },
];

const faqs = [
  { q: 'Wie viel darf ich 2026 maximal in die Saeule 3a einzahlen?', a: `Mit Pensionskasse maximal CHF ${new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxMitPK)}. Ohne Pensionskasse maximal 20% des Nettoeinkommens oder CHF ${new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxOhnePK)} (kleinerer Wert zaehlt). Quelle: BSV, Verordnung BVV 3.` },
  { q: 'Bis wann muss die Einzahlung 2026 erfolgen?', a: 'Fuer das Steuerjahr 2026 muss die Einzahlung spaetestens am 31. Dezember 2026 auf dem Vorsorgekonto eingehen. Viele Anbieter empfehlen Einzahlung bis Mitte Dezember, um Verbuchungsfristen einzuhalten.' },
  { q: 'Wie viel Steuern spare ich mit einer maximalen 3a-Einzahlung?', a: `Die Steuerersparnis haengt von deinem Grenzsteuersatz ab. Typisch sind CHF 1'500 bis 2'500 pro Jahr bei einer Maximaleinzahlung von CHF ${new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxMitPK)}. In Kantonen mit hohen Steuern (z.B. GE, VD) kann die Ersparnis hoeher ausfallen, in ZG oder SZ tiefer.` },
  { q: 'Kann ich Beitragsluecken nachtraeglich schliessen?', a: 'Ja, ab 2026 sind nachtraegliche Einzahlungen erstmals moeglich, aber nur fuer Luecken ab 2025. Du kannst bis zu 10 Jahre rueckwirkend nachzahlen, maximal CHF 7\'258 pro Lueckenjahr.' },
  { q: 'Soll ich monatlich oder einmal jaehrlich einzahlen?', a: 'Januar-Einzahlung bringt maximale Rendite, da das Geld das ganze Jahr investiert bleibt. Monatlicher Dauerauftrag von CHF 604.85 (= 7\'258 / 12) ist die Alternative fuer bessere Liquiditaetsplanung.' },
  { q: 'Was passiert bei Uebereinzahlung?', a: 'Betraege ueber dem Maximum sind nicht steuerlich abzugsfaehig. Viele Anbieter weisen Ueberzahlungen automatisch zurueck. Bei mehreren 3a-Konten zaehlen alle Einzahlungen zusammen.' },
  { q: 'Wann kann ich das 3a-Guthaben beziehen?', a: 'Fruehestens 5 Jahre vor dem Referenzalter (also ab Alter 60). Vorzeitige Bezuege nur bei Eigenheimerwerb, selbstaendiger Erwerbstaetigkeit oder Ausreise. Bei Bezug wird das Kapital reduziert besteuert.' },
  { q: 'Lohnt sich die Saeule 3a fuer mich?', a: 'Fast immer ja, wenn du AHV-pflichtiges Einkommen hast und Steuern zahlst. Je hoeher dein Einkommen und Grenzsteuersatz, desto groesser der Vorteil.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Saeule 3a Rechner 2026',
  url: 'https://loadouts.info/de/saeule-3a-rechner',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'de',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: 'https://loadouts.info/de/' },
    { '@type': 'ListItem', position: 2, name: 'Saeule 3a Rechner', item: 'https://loadouts.info/de/saeule-3a-rechner' },
  ],
};
---
<BaseLayout title={title} description={description} lang="de" canonicalSlug="saeule-3a-rechner" altSlug="pillar-3a-calculator">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/de/" class="hover:text-[#1E3A8A]">Start</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Saeule 3a Rechner</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Saeule 3a Rechner 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    Die Saeule 3a ist die private, steuerbeguenstigte Vorsorge in der Schweiz. 2026 darfst du maximal
    <strong>CHF {new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxMitPK)}</strong> einzahlen,
    wenn du einer Pensionskasse angehoerst. Ohne Pensionskasse sind bis zu <strong>20% deines Netto-Erwerbseinkommens</strong>
    abziehbar, maximal <strong>CHF {new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxOhnePK)}</strong>.
  </p>

  <Saeule3a client:load lang="de" maxMitPK={CH2026.saeule3a.maxMitPK} maxOhnePK={CH2026.saeule3a.maxOhnePK} />

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Haeufige Fragen zur Saeule 3a</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <SourceBox client:load federalSources={federalSources} lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
