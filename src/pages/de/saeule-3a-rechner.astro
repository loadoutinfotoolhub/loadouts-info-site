---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Saeule3a from '../../components/calculators/Saeule3a.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';
import { CH2026, CH2026Sourced } from '../../lib/ch-constants';

const title = 'Säule 3a Rechner 2026: Maximalbetrag & Steuerersparnis | loadouts.info';
const description = 'Berechne sofort deinen Säule 3a Maximalbetrag und die Steuerersparnis für 2026. Gratis, ohne Anmeldung. Alle Kantone.';

const federalSources = [
  { displayName: CH2026Sourced.saeule3a.maxMitPK.source.displayName, url: CH2026Sourced.saeule3a.maxMitPK.source.url, legalBasis: CH2026Sourced.saeule3a.maxMitPK.source.legalBasis },
  { displayName: 'Fedlex - BVV 3 (Verordnung)', url: 'https://www.fedlex.admin.ch/eli/cc/1985/2_2_2/de' },
  { displayName: 'Informationsstelle AHV/IV', url: 'https://www.ahv-iv.ch/de/Sozialversicherungen' },
];

const faqs = [
  { q: 'Wie viel darf ich 2026 maximal in die Säule 3a einzahlen?', a: `Mit Pensionskasse maximal CHF ${new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxMitPK)}. Ohne Pensionskasse maximal 20% des Nettoeinkommens oder CHF ${new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxOhnePK)} (kleinerer Wert zählt). Quelle: BSV, Verordnung BVV 3.` },
  { q: 'Bis wann muss die Einzahlung 2026 erfolgen?', a: 'Für das Steuerjahr 2026 muss die Einzahlung spätestens am 31. Dezember 2026 auf dem Vorsorgekonto eingehen. Viele Anbieter empfehlen Einzahlung bis Mitte Dezember, um Verbuchungsfristen einzuhalten.' },
  { q: 'Wie viel Steuern spare ich mit einer maximalen 3a-Einzahlung?', a: `Die Steuerersparnis hängt von deinem Grenzsteuersatz ab. Typisch sind CHF 1'500 bis 2'500 pro Jahr bei einer Maximaleinzahlung von CHF ${new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxMitPK)}. In Kantonen mit hohen Steuern (z.B. GE, VD) kann die Ersparnis höher ausfallen, in ZG oder SZ tiefer.` },
  { q: 'Kann ich Beitragslücken nachträglich schliessen?', a: 'Ja, ab 2026 sind nachträgliche Einzahlungen erstmals möglich, aber nur für Lücken ab 2025. Du kannst bis zu 10 Jahre rückwirkend nachzahlen, maximal CHF 7\'258 pro Lückenjahr.' },
  { q: 'Soll ich monatlich oder einmal jährlich einzahlen?', a: 'Januar-Einzahlung bringt maximale Rendite, da das Geld das ganze Jahr investiert bleibt. Monatlicher Dauerauftrag von CHF 604.85 (= 7\'258 / 12) ist die Alternative für bessere Liquiditätsplanung.' },
  { q: 'Was passiert bei Übereinzahlung?', a: 'Beträge über dem Maximum sind nicht steuerlich abzugsfähig. Viele Anbieter weisen Überzahlungen automatisch zurück. Bei mehreren 3a-Konten zählen alle Einzahlungen zusammen.' },
  { q: 'Wann kann ich das 3a-Guthaben beziehen?', a: 'Frühestens 5 Jahre vor dem Referenzalter (also ab Alter 60). Vorzeitige Bezüge nur bei Eigenheimerwerb, selbständiger Erwerbstätigkeit oder Ausreise. Bei Bezug wird das Kapital reduziert besteuert.' },
  { q: 'Lohnt sich die Säule 3a für mich?', a: 'Fast immer ja, wenn du AHV-pflichtiges Einkommen hast und Steuern zahlst. Je höher dein Einkommen und Grenzsteuersatz, desto grösser der Vorteil.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Säule 3a Rechner 2026',
  url: 'https://loadouts.info/de/saeule-3a-rechner',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'de',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: 'https://loadouts.info/de/' },
    { '@type': 'ListItem', position: 2, name: 'Säule 3a Rechner', item: 'https://loadouts.info/de/saeule-3a-rechner' },
  ],
};

const glossaryDE = [
  { term: 'Säule 3a', definition: 'Die freiwillige, private Vorsorge in der Schweiz. Einzahlungen sind vom steuerbaren Einkommen abziehbar. Gehört zum 3-Säulen-System neben der AHV (1. Säule) und der Pensionskasse (2. Säule).' },
  { term: 'Pensionskasse (PK)', definition: 'Die berufliche Vorsorge (2. Säule). Dein Arbeitgeber zahlt zusammen mit dir Beiträge ein. Ob du einer PK angehörst, bestimmt deinen maximalen 3a-Beitrag.' },
  { term: 'Grenzsteuersatz', definition: 'Der Steuersatz, der auf den letzten Franken deines Einkommens anfällt. Er bestimmt, wie viel Steuern du pro zusätzlich einbezahltem Franken in die Säule 3a sparst.' },
  { term: 'BVG', definition: 'Bundesgesetz über die berufliche Alters-, Hinterlassenen- und Invalidenvorsorge. Regelt die Mindestanforderungen an die Pensionskasse.' },
  { term: 'Selbständigerwerbende', definition: 'Personen, die auf eigene Rechnung arbeiten und keinem Arbeitgeber angeschlossen sind. Sie haben oft keine Pensionskasse und dürfen darum mehr in die Säule 3a einzahlen.' },
  { term: 'Kapitalauszahlung', definition: 'Wenn du dein 3a-Guthaben auf einmal auszahlen lässt statt als Rente. Wird separat und reduziert besteuert.' },
  { term: 'Sperrfrist', definition: 'Zeitraum, in dem du dein 3a-Guthaben nicht beziehen kannst. Das Geld ist bis 5 Jahre vor dem Referenzalter gesperrt, mit Ausnahmen.' },
  { term: 'Vorbezug', definition: 'Bezug des 3a-Guthabens vor dem Referenzalter. Möglich bei Eigenheimerwerb, Selbständigkeit oder definitiver Ausreise aus der Schweiz.' },
  { term: 'WEF-Vorbezug', definition: 'Vorbezug für Wohneigentum zur Eigennutzung (Wohneigentumsförderung). Du kannst 3a-Geld für den Kauf oder die Renovation deines Eigenheims verwenden.' },
];
---
<BaseLayout title={title} description={description} lang="de" canonicalSlug="saeule-3a-rechner" altSlug="pillar-3a-calculator">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/de/" class="hover:text-[#1E3A8A]">Start</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Säule 3a Rechner</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Säule 3a Rechner 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    Die <TermTooltip client:load term="Säule 3a" definition="Die freiwillige, private Vorsorge in der Schweiz. Einzahlungen sind vom steuerbaren Einkommen abziehbar." /> ist die private, steuerbegünstigte Vorsorge in der Schweiz. 2026 darfst du maximal
    <strong>CHF {new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxMitPK)}</strong> einzahlen,
    wenn du einer <TermTooltip client:load term="Pensionskasse" definition="Die berufliche Vorsorge (2. Säule). Dein Arbeitgeber zahlt zusammen mit dir Beiträge ein." /> angehörst. Ohne Pensionskasse sind bis zu <strong>20% deines Netto-Erwerbseinkommens</strong>
    abziehbar, maximal <strong>CHF {new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxOhnePK)}</strong>.
  </p>

  <Saeule3a client:load lang="de" maxMitPK={CH2026.saeule3a.maxMitPK} maxOhnePK={CH2026.saeule3a.maxOhnePK} />

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Häufige Fragen zur Säule 3a</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <SourceBox client:load federalSources={federalSources} lang="de" />

  <GlossarySection client:load entries={glossaryDE} lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
