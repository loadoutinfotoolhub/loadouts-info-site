---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Tragbarkeit from '../../components/calculators/Tragbarkeit.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';

const title = 'Hypothek-Tragbarkeit Rechner 2026: Kann ich mir das Haus leisten? | loadouts.info';
const description = 'Berechne sofort, ob dein Einkommen für die Schweizer Hypothek reicht. Kalkulatorischer Zins, Eigenkapital, Amortisation. Gratis.';

const federalSources = [
  { displayName: 'FINMA / Schweizerische Bankiervereinigung', url: 'https://www.finma.ch/en/documentation/dossier/dossier-hypothekarmarkt/', legalBasis: 'SBVg Richtlinien Mindestanforderungen Hypothekarfinanzierung' },
  { displayName: 'Fedlex: BVG (Vorbezug für Wohneigentum)', url: 'https://www.fedlex.admin.ch/eli/cc/1983/797_797_797/de' },
];

const faqs = [
  { q: 'Wie viel Hypothek kann ich mir leisten?', a: 'Faustformel: Dein Bruttoeinkommen muss mindestens das 3-fache der jährlichen Wohnkosten ausmachen. Bei einer Hypothek von CHF 800\'000 und kalkulatorischem Zins von 5% brauchst du ca. CHF 175\'000 Bruttoeinkommen.' },
  { q: 'Warum rechnet die Bank mit 5% Zins?', a: 'Der kalkulatorische Zinssatz von 5% ist eine Vorgabe der FINMA und SBVg. Er schützt dich und die Bank vor Zinsanstiegen. Auch wenn aktuelle Zinsen 1-2% betragen, wird mit 5% gerechnet.' },
  { q: 'Wie viel Eigenkapital brauche ich?', a: 'Mindestens 20% des Kaufpreises. Davon müssen 10% aus harten Mitteln stammen (Erspartes, Wertschriften). Die restlichen 10% können aus Pensionskasse oder Säule 3a kommen.' },
  { q: 'Was bedeutet Amortisation?', a: 'Die Rückzahlung der Hypothek. In der Schweiz muss die Hypothek innerhalb von 15 Jahren auf zwei Drittel des Immobilienwerts amortisiert werden.' },
  { q: 'Was ist der Unterschied zwischen 1. und 2. Hypothek?', a: 'Die 1. Hypothek finanziert bis 66% des Immobilienwerts und muss nicht zwingend amortisiert werden. Die 2. Hypothek (66-80%) muss in 15 Jahren zurückbezahlt werden.' },
  { q: 'Was sind typische Nebenkosten?', a: 'Als Faustregel: 1% des Immobilienwerts pro Jahr für Unterhalt, plus Heizung, Strom, Versicherungen. Für ein CHF 1 Mio Haus ca. CHF 10\'000 bis 15\'000 jährlich.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const appSchema = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Hypothek-Tragbarkeit Rechner 2026', url: 'https://loadouts.info/de/hypothek-tragbarkeit', applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' }, inLanguage: 'de' };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Start', item: 'https://loadouts.info/de/' }, { '@type': 'ListItem', position: 2, name: 'Hypothek-Tragbarkeit', item: 'https://loadouts.info/de/hypothek-tragbarkeit' }] };

const glossaryDE = [
  { term: 'Tragbarkeit', definition: 'Prüfung, ob dein Einkommen ausreicht, um die Hypothek langfristig zu tragen. Die Wohnkosten dürfen maximal 33% des Bruttoeinkommens ausmachen.' },
  { term: 'Kalkulatorischer Zins', definition: 'Ein theoretischer Zinssatz von 5%, mit dem Banken die Tragbarkeit berechnen. Schützt vor Problemen bei Zinsanstiegen.' },
  { term: 'Amortisation', definition: 'Die Rückzahlung der Hypothek. Die 2. Hypothek (über 66% Belehnung) muss in 15 Jahren zurückbezahlt werden.' },
  { term: 'Eigenkapital', definition: 'Dein eigenes Geld, das du beim Hauskauf einbringst. Minimum 20% des Kaufpreises, davon 10% aus harten Mitteln.' },
  { term: '1. Hypothek', definition: 'Finanziert bis 66% des Immobilienwerts. Muss nicht zwingend amortisiert werden.' },
  { term: '2. Hypothek', definition: 'Finanziert 66-80% des Immobilienwerts. Muss zwingend in 15 Jahren zurückbezahlt werden.' },
  { term: 'Belehnung', definition: 'Der Anteil des Immobilienwerts, der durch die Hypothek finanziert wird. Maximum 80%.' },
  { term: 'Nebenkosten-Pauschale', definition: 'Jährliche Kosten für Unterhalt, Reparaturen und Betrieb. Banken rechnen mit ca. 1% des Immobilienwerts.' },
];
---
<BaseLayout title={title} description={description} lang="de" canonicalSlug="hypothek-tragbarkeit" altSlug="mortgage-affordability">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/de/" class="hover:text-[#1E3A8A]">Start</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Hypothek-Tragbarkeit</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Hypothek-Tragbarkeit Rechner 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    Eine Schweizer Hypothek ist <TermTooltip client:load term="tragbar" definition="Die Wohnkosten dürfen maximal 33% deines Bruttoeinkommens ausmachen." />,
    wenn die Wohnkosten nicht mehr als 33% deines Bruttoeinkommens ausmachen. Die Bank rechnet mit einem
    <TermTooltip client:load term="kalkulatorischen Zinssatz" definition="Ein theoretischer Zinssatz von 5%, mit dem Banken rechnen, um Zinsanstiege abzusichern." /> von 5%.
    Du brauchst mindestens 20% <TermTooltip client:load term="Eigenkapital" definition="Dein eigenes Geld beim Hauskauf. Davon müssen 10% aus harten Mitteln stammen." />.
  </p>

  <Tragbarkeit client:load lang="de" />

  <p class="mt-6 text-sm text-[#4B5563] italic">
    Die Berechnungen auf loadouts.info sind unverbindliche Schätzungen und stellen keine Anlage-, Steuer- oder Rechtsberatung dar.
  </p>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Häufige Fragen zur Hypothek-Tragbarkeit</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <SourceBox client:load federalSources={federalSources} lang="de" />
  <GlossarySection client:load entries={glossaryDE} lang="de" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
