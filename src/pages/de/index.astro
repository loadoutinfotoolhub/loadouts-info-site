---
import { getCollection } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import WhatIsLoadout from '@/components/sections/WhatIsLoadout.astro';
import CategoryGrid from '@/components/sections/CategoryGrid.astro';
import FeaturedLoadout from '@/components/sections/FeaturedLoadout.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';

const all = await getCollection('loadouts');
const featured = all.find((l) => l.data.slug === 'hyrox-beginner') ?? all[0];
---
<BaseLayout
  lang="de"
  title="loadouts.info — Das richtige Setup für dein Hobby, deinen Sport, dein Leben"
  description="Wir zeigen dir welche Ausrüstung du wirklich brauchst — als Einsteiger, Fortgeschrittener oder Profi. Klar strukturiert, ehrlich bewertet."
  canonical="https://loadouts.info/de/"
  dePath="/de/"
  enPath="/en/"
>
  <HeroSection lang="de" />
  <WhatIsLoadout lang="de" />
  <CategoryGrid lang="de" />
  {featured && <FeaturedLoadout loadout={featured} lang="de" />}
  <HowItWorks lang="de" />
</BaseLayout>
