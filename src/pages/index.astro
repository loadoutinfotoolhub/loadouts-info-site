---
// Root-Redirect auf Default-Locale /de/. Static-HTML-Fallback falls
// Cloudflare _redirects nicht greift.
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0;url=/de/" />
    <link rel="canonical" href="https://loadouts.info/de/" />
    <meta name="robots" content="noindex" />
    <title>loadouts.info</title>
    <script>window.location.replace('/de/');</script>
  </head>
  <body>
    <p>Weiter zu <a href="/de/">loadouts.info</a>.</p>
  </body>
</html>
