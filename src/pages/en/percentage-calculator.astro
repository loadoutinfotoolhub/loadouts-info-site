---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Prozentrechner from '../../components/calculators/Prozentrechner.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';

const title = 'Percentage Calculator: Percent, Share, Change | loadouts.info';
const description = 'Calculate percentages quickly: percentage value, base value, percentage rate, percentage change. Free, instant, no registration.';

const faqs = [
  { q: 'How do I calculate a percentage?', a: 'Percentage = (Part / Whole) x 100. Example: 15 out of 200 is 7.5%. Simply enter both values into our calculator.' },
  { q: 'How do I calculate percentage change?', a: 'Percentage change = ((New value - Old value) / Old value) x 100. A positive result indicates an increase, a negative result a decrease.' },
  { q: 'What is the difference between percentage points and percent?', a: 'If an interest rate rises from 2% to 3%, that is an increase of 1 percentage point but a 50% increase. Percentage points measure the absolute difference, percent measures the relative change.' },
  { q: 'How do I calculate a discount in percent?', a: 'Discount amount = Original price x (Discount % / 100). Final price = Original price - Discount. For a 20% discount on CHF 150: Discount = CHF 30, final price = CHF 120.' },
  { q: 'How do I convert gross to net?', a: 'Net = Gross / (1 + tax rate). For Swiss VAT at 8.1% standard rate: Net = Gross / 1.081. For more precise VAT calculations, use our VAT Calculator.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Percentage Calculator',
  url: 'https://loadouts.info/en/percentage-calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'en',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://loadouts.info/en/' },
    { '@type': 'ListItem', position: 2, name: 'Percentage Calculator', item: 'https://loadouts.info/en/percentage-calculator' },
  ],
};

const glossaryEN = [
  { term: 'Percentage rate', definition: 'A ratio expressed in hundredths. 25% means 25 out of 100 or one quarter of the base value.' },
  { term: 'Base value', definition: 'The starting value (100%) that the percentage calculation refers to. Example: in "20% of 500", 500 is the base value.' },
  { term: 'Percentage value', definition: 'The result of the percentage calculation in absolute numbers. Example: 20% of 500 gives the percentage value 100.' },
  { term: 'Percentage change', definition: 'The relative change between an old and a new value, expressed as a percent. Shows growth (positive) or decline (negative).' },
  { term: 'Percentage point', definition: 'The absolute difference between two percentage values. If a rate rises from 5% to 8%, that is 3 percentage points but a 60% increase.' },
];
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="percentage-calculator" altSlug="prozentrechner">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/en/" class="hover:text-[#1E3A8A]">Home</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Percentage Calculator</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Percentage Calculator</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    This calculator solves all common percentage problems involving
    <TermTooltip client:load term="percentage rate" definition="A ratio expressed in hundredths. 25% means 25 out of 100." />,
    <TermTooltip client:load term="base value" definition="The starting value (100%) that the calculation refers to." />, and
    <TermTooltip client:load term="percentage value" definition="The result of the percentage calculation in absolute numbers." />.
    Also calculate the percentage change between two values.
  </p>

  <Prozentrechner client:load lang="en" />

  <div class="mt-12 bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-[#4B5563]">
    Calculations on loadouts.info are non-binding estimates and do not constitute financial, tax, or legal advice.
  </div>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <GlossarySection client:load entries={glossaryEN} lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
