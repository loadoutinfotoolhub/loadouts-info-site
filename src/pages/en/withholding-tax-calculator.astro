---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Quellensteuer from '../../components/calculators/Quellensteuer.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';

const title = 'Swiss Withholding Tax Calculator 2026: Tariff, Canton, Deduction | loadouts.info';
const description = 'Calculate your Swiss withholding tax (Quellensteuer) for 2026 by tariff, canton, and income. All 7 cantons, with NOV recommendation. Free.';

const federalSources = [
  { displayName: 'Federal Tax Administration FTA', url: 'https://www.estv.admin.ch/estv/en/home/direct-federal-tax/withholding-tax.html', legalBasis: 'Art. 83ff. DBG' },
  { displayName: 'Fedlex - Withholding Tax Ordinance', url: 'https://www.fedlex.admin.ch/eli/cc/1993/1370_1370_1370/en' },
  { displayName: 'Federal Social Insurance Office BSV', url: 'https://www.bsv.admin.ch/en/contributions-overview' },
];

const cantonSources: Record<string, {name: string, url: string}[]> = {
  ZH: [{ name: 'Tax Office Canton Zurich', url: 'https://www.zh.ch/de/steuern-finanzen/steuern/quellensteuer.html' }],
  BE: [{ name: 'Tax Administration Canton Bern', url: 'https://www.sv.fin.be.ch/de/start/dienstleistungen/quellensteuer.html' }],
  VD: [{ name: 'Cantonal Tax Administration VD', url: 'https://www.vd.ch/themes/etat-droit-finances/impots/impot-a-la-source' }],
  GE: [{ name: 'Cantonal Tax Administration GE', url: 'https://www.ge.ch/impot-source' }],
  AG: [{ name: 'Tax Office Canton Aargau', url: 'https://www.ag.ch/de/verwaltung/dfr/steuern/quellensteuer' }],
  ZG: [{ name: 'Tax Administration Canton Zug', url: 'https://www.zg.ch/behoerden/finanzdirektion/steuerverwaltung/quellensteuer' }],
  BS: [{ name: 'Tax Administration Basel-Stadt', url: 'https://www.steuerverwaltung.bs.ch/quellensteuer.html' }],
};

const faqs = [
  { q: 'Who pays withholding tax in Switzerland?', a: 'Foreign employees without a C settlement permit pay withholding tax. The employer deducts it directly from the salary. This applies to holders of B, L, F, N permits and cross-border commuters (G permit).' },
  { q: 'What do tariff codes A, B, C, H mean?', a: 'Tariff A: single. Tariff B: married, sole earner. Tariff C: married, both working. Tariff H: single parent. The digit (0-3) indicates the number of children.' },
  { q: 'What is the subsequent ordinary assessment (NOV)?', a: 'Above CHF 120,000 annual gross, withholding tax payers must file a regular tax return. Below this threshold, you can apply voluntarily, which can pay off with high deductions (pillar 3a, professional expenses). Deadline: March 31 of the following year.' },
  { q: 'Can I get withholding tax refunded?', a: 'Yes, through the subsequent ordinary assessment (NOV). If your actual deductions exceed those included in the withholding tax tariff, you receive the difference back.' },
  { q: 'How does withholding tax vary by canton?', a: 'Rates vary significantly. Zug has the lowest, Geneva the highest rates. The canton of your workplace determines the rate, not your residential canton.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const webAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Swiss Withholding Tax Calculator 2026',
  url: 'https://loadouts.info/en/withholding-tax-calculator',
  applicationCategory: 'FinanceApplication',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'en',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://loadouts.info/en/' },
    { '@type': 'ListItem', position: 2, name: 'Withholding Tax Calculator', item: 'https://loadouts.info/en/withholding-tax-calculator' },
  ],
};

const glossaryEN = [
  { term: 'Withholding tax (Quellensteuer)', definition: 'Tax deducted directly from foreign employees\' salaries by the employer. Replaces ordinary income tax for persons without C settlement permit.' },
  { term: 'Tariff A/B/C/H', definition: 'Withholding tax categories. A = single, B = married (sole earner), C = married (dual income), H = single parent. The digit shows the number of children.' },
  { term: 'Subsequent ordinary assessment (NOV)', definition: 'Regular tax return for withholding tax payers. Mandatory above CHF 120,000 annual income, voluntary below. Can lead to refunds.' },
  { term: 'Cross-border commuter', definition: 'Persons with G permit who commute daily or weekly between their country of residence and Switzerland. Special tax rules apply depending on country of origin.' },
  { term: 'Effective tax rate', definition: 'The actual percentage of your income deducted as withholding tax. Includes federal, cantonal, and municipal tax.' },
];
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="withholding-tax-calculator" altSlug="quellensteuer-rechner">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/en/" class="hover:text-[#1E3A8A]">Home</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Withholding Tax Calculator</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Swiss Withholding Tax Calculator 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    <TermTooltip client:load term="Withholding tax" definition="Tax deducted directly from your salary by the employer. Applies to foreign employees without a C settlement permit." />
    (Quellensteuer) in Switzerland is deducted directly from your salary and includes federal, cantonal, and municipal tax in one rate.
    Calculate your monthly deduction by canton, tariff, and income.
  </p>

  <Quellensteuer client:load lang="en" />

  <div class="mt-12 bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-[#4B5563]">
    Calculations on loadouts.info are non-binding estimates and do not constitute financial, tax, or legal advice.
  </div>

  <SourceBox client:load federalSources={federalSources} cantonSources={cantonSources} lang="en" />

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      {faqs.map(f => (
        <div class="border-b border-gray-100 pb-4">
          <h3 class="font-medium text-[#1E3A8A] mb-2">{f.q}</h3>
          <p class="text-sm text-[#4B5563] leading-relaxed">{f.a}</p>
        </div>
      ))}
    </div>
  </section>

  <GlossarySection client:load entries={glossaryEN} lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
