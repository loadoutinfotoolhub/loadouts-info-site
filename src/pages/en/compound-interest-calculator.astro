---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Zinseszins from '../../components/calculators/Zinseszins.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';

const title = 'Compound Interest Calculator 2026: Capital Growth | loadouts.info';
const description = 'Calculate compound interest on your capital with monthly or annual contributions. Free, instant, no registration required.';

const faqs = [
  { q: 'What is compound interest?', a: 'With compound interest, earned interest is reinvested rather than paid out. This means you earn interest on a larger balance the following year. Over long periods, this leads to exponential growth.' },
  { q: 'How do I calculate compound interest?', a: 'The formula is: Final capital = Starting capital x (1 + interest rate)^number of years. With regular contributions, a savings rate component is added. Our calculator handles this automatically.' },
  { q: 'What does the compound interest effect look like in practice?', a: 'Example: CHF 10,000 at 5% interest doubles to roughly CHF 20,000 after about 14 years. After 28 years it reaches CHF 40,000. The longer the investment horizon, the stronger the effect.' },
  { q: 'What is the difference between simple and compound interest?', a: 'Simple interest is calculated only on the original principal. Compound interest is calculated on the principal plus previously earned interest. Over 20 years, the difference can exceed 30%.' },
  { q: 'What interest rate is realistic?', a: 'Swiss savings account: about 0.5 to 1.5%. Pillar 3a securities solution: historically about 4 to 6% p.a. Global equities: roughly 7% nominal long-term. Always subtract inflation for the real return.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Compound Interest Calculator',
  url: 'https://loadouts.info/en/compound-interest-calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'en',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://loadouts.info/en/' },
    { '@type': 'ListItem', position: 2, name: 'Compound Interest Calculator', item: 'https://loadouts.info/en/compound-interest-calculator' },
  ],
};

const glossaryEN = [
  { term: 'Compound interest', definition: 'Interest earned on previously accumulated interest. This causes capital to grow exponentially rather than linearly.' },
  { term: 'Nominal interest rate', definition: 'The stated interest rate before accounting for inflation. Subtract the inflation rate to get the real return.' },
  { term: 'Savings rate', definition: 'The amount you contribute regularly (e.g. monthly or annually) in addition to your starting capital.' },
  { term: 'Investment horizon', definition: 'The planned duration of your investment in years. The longer the horizon, the stronger the compound interest effect.' },
  { term: 'Real interest rate', definition: 'The interest rate after subtracting inflation. Shows how much purchasing power your capital actually gains.' },
];
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="compound-interest-calculator" altSlug="zinseszins-rechner">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/en/" class="hover:text-[#1E3A8A]">Home</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Compound Interest Calculator</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Compound Interest Calculator</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    <TermTooltip client:load term="Compound interest" definition="Interest earned on previously accumulated interest. Capital grows exponentially rather than linearly." />
    is the most powerful lever for long-term wealth building. Enter your starting capital, annual
    <TermTooltip client:load term="savings rate" definition="The amount you contribute regularly, e.g. monthly or annually." />,
    and expected interest rate to see how your capital grows over time.
  </p>

  <Zinseszins client:load lang="en" />

  <div class="mt-12 bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-[#4B5563]">
    Calculations on loadouts.info are non-binding estimates and do not constitute financial, tax, or legal advice.
  </div>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <GlossarySection client:load entries={glossaryEN} lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
