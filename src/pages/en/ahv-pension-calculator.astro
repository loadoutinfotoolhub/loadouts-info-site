---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AhvRente from '../../components/calculators/AhvRente.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';
import { CH2026, CH2026Sourced } from '../../lib/ch-constants';

const fmtCHF = (v: number) => new Intl.NumberFormat('de-CH').format(v);

const title = 'AHV Pension Calculator 2026: Estimate Your Swiss State Pension | loadouts.info';
const description = `Calculate your AHV pension for 2026. Maximum CHF ${fmtCHF(CH2026.ahvRenten.maxEinzelMonat)}/month, minimum CHF ${fmtCHF(CH2026.ahvRenten.minEinzelMonat)}/month. Free, no registration.`;

const federalSources = [
  { displayName: 'Federal Social Insurance Office (BSV)', url: CH2026Sourced.ahvRenten.maxEinzelMonat.source.url, legalBasis: CH2026Sourced.ahvRenten.maxEinzelMonat.source.legalBasis },
  { displayName: 'Fedlex - AHVG (Federal Old-Age Insurance Act)', url: 'https://www.fedlex.admin.ch/eli/cc/1952/1021_1046_1050/en' },
  { displayName: 'AHV/IV Information Centre', url: 'https://www.ahv-iv.ch/en/Social-insurances/Old-age-and-survivors-insurance-OASI/Old-age-pensions' },
];

const faqs = [
  { q: 'What is the maximum AHV pension in 2026?', a: `The maximum individual pension is CHF ${fmtCHF(CH2026.ahvRenten.maxEinzelMonat)} per month. Married couples receive a combined maximum of CHF ${fmtCHF(CH2026.ahvRenten.maxEhepaarMonat)} per month (capped at 150% of the individual maximum).` },
  { q: 'What is the minimum AHV pension?', a: `The minimum pension is CHF ${fmtCHF(CH2026.ahvRenten.minEinzelMonat)} per month. It is paid when there are gaps in contribution periods and a low average annual income.` },
  { q: 'What determines the amount of my AHV pension?', a: 'Three factors: contribution duration (gaps reduce the pension), average annual income during your working life, and any child-raising or caregiving credits.' },
  { q: 'When do I receive the full AHV pension?', a: 'You receive the full pension with an uninterrupted contribution history from age 21 to reference age 65. Each missing contribution year reduces the pension by approximately 1/44 of the full amount.' },
  { q: 'Can I take my AHV pension early or defer it?', a: 'Early withdrawal is possible up to 2 years before reference age, with a reduction of 6.8% per year. Deferral is possible for up to 5 years after reference age, earning a supplement of 5.2% to 31.5%.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'AHV Pension Calculator 2026',
  url: 'https://loadouts.info/en/ahv-pension-calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'en',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://loadouts.info/en/' },
    { '@type': 'ListItem', position: 2, name: 'AHV Pension Calculator', item: 'https://loadouts.info/en/ahv-pension-calculator' },
  ],
};

const glossaryEN = [
  { term: 'AHV (Old-Age and Survivors\' Insurance)', definition: 'The 1st pillar of Swiss retirement provision. Mandatory for all employed persons. Funded through salary contributions from employee and employer.' },
  { term: 'Reference age', definition: 'The standard retirement age in Switzerland, currently 65 for both men and women (following AHV 21 reform). From this age, you are entitled to the full AHV pension.' },
  { term: 'Contribution duration', definition: 'The number of years during which you paid AHV contributions. A complete contribution history from age 21 to reference age yields the full pension.' },
  { term: 'Capping (Plafonierung)', definition: 'Limitation of the combined married couple pension to 150% of the individual maximum. Applies when both spouses receive an AHV pension.' },
  { term: 'Child-raising credits', definition: 'Notional income added to your average annual earnings for years spent raising children. Increases your AHV pension.' },
];
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="ahv-pension-calculator" altSlug="ahv-rentenrechner">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/en/" class="hover:text-[#1E3A8A]">Home</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">AHV Pension Calculator</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">AHV Pension Calculator 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    The <TermTooltip client:load term="AHV" definition="Old-Age and Survivors' Insurance, the 1st pillar of Swiss retirement provision. Mandatory for all employed persons." />
    is the foundation of Swiss retirement provision. In 2026, the maximum pension is
    <strong>CHF {fmtCHF(CH2026.ahvRenten.maxEinzelMonat)}</strong> per month, while the
    <TermTooltip client:load term="minimum pension" definition={`The lowest possible AHV pension of CHF ${fmtCHF(CH2026.ahvRenten.minEinzelMonat)} per month for incomplete contribution histories.`} />
    is <strong>CHF {fmtCHF(CH2026.ahvRenten.minEinzelMonat)}</strong>. Calculate your expected pension here.
  </p>

  <AhvRente client:load lang="en" maxEinzelMonat={CH2026.ahvRenten.maxEinzelMonat} minEinzelMonat={CH2026.ahvRenten.minEinzelMonat} maxEhepaarMonat={CH2026.ahvRenten.maxEhepaarMonat} />

  <div class="mt-12 bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-[#4B5563]">
    Calculations on loadouts.info are non-binding estimates and do not constitute financial, tax, or legal advice.
  </div>

  <SourceBox client:load federalSources={federalSources} lang="en" />

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <GlossarySection client:load entries={glossaryEN} lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
