---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Privacy Policy | loadouts.info';
const description = 'Privacy policy of loadouts.info in accordance with Swiss DPA and GDPR.';
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="privacy" altSlug="datenschutz" noindex={true}>
  <h1 class="text-3xl font-bold text-[#1E3A8A] mb-6">Privacy Policy</h1>

  <div class="prose max-w-prose text-[#4B5563] space-y-4">
    <h2 class="text-xl font-semibold text-[#1E3A8A]">1. Data Controller</h2>
    <p>
      NACHNAME_PLATZHALTER<br />
      ADRESSE_PLATZHALTER<br />
      feedback@loadouts.info
    </p>

    <h2 class="text-xl font-semibold text-[#1E3A8A]">2. Data Collection</h2>
    <p>
      loadouts.info does not collect or store personal data. All calculations are performed
      exclusively in the browser (client-side). No input data is transmitted to a server.
    </p>

    <h2 class="text-xl font-semibold text-[#1E3A8A]">3. Hosting</h2>
    <p>
      The website is hosted on Cloudflare Pages. Cloudflare automatically collects
      technical access data (IP address, browser type, access time). This data is processed
      by Cloudflare according to their privacy policy.
    </p>

    <h2 class="text-xl font-semibold text-[#1E3A8A]">4. Cookies</h2>
    <p>
      loadouts.info currently does not use cookies. Should a cookie banner be introduced
      in the future, this page will be updated accordingly.
    </p>

    <h2 class="text-xl font-semibold text-[#1E3A8A]">5. External Links</h2>
    <p>
      Our pages contain links to official Swiss federal agencies (admin.ch).
      We have no control over the privacy practices of these external sites.
    </p>

    <h2 class="text-xl font-semibold text-[#1E3A8A]">6. Your Rights</h2>
    <p>
      You have the right to access, rectify, and delete your data.
      Since we do not collect personal data, this only applies to any email correspondence.
      Contact: feedback@loadouts.info
    </p>

    <h2 class="text-xl font-semibold text-[#1E3A8A]">7. Changes</h2>
    <p>
      We reserve the right to modify this privacy policy at any time.
      The current version applies from the time of publication on this page.
    </p>

    <p class="text-xs text-[#4B5563] mt-8">Last updated: 13.04.2026</p>
  </div>
</BaseLayout>
