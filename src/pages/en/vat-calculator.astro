---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MwstRechner from '../../components/calculators/MwstRechner.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';
import { CH2026, CH2026Sourced } from '../../lib/ch-constants';

const title = 'Swiss VAT Calculator 2026: Standard, Reduced & Accommodation Rate | loadouts.info';
const description = 'Calculate Swiss VAT for 2026: standard rate 8.1%, reduced 2.6%, accommodation 3.8%. Convert net to gross and back instantly.';

const normalPct = (CH2026.mwst.normal * 100).toFixed(1);
const reduzPct = (CH2026.mwst.reduziert * 100).toFixed(1);
const beherPct = (CH2026.mwst.beherbergung * 100).toFixed(1);

const federalSources = [
  { displayName: 'Federal Tax Administration FTA', url: CH2026Sourced.mwst.normal.source.url, legalBasis: CH2026Sourced.mwst.normal.source.legalBasis },
  { displayName: 'Fedlex - Value Added Tax Act (MWSTG)', url: 'https://www.fedlex.admin.ch/eli/cc/2009/615/en' },
];

const faqs = [
  { q: 'What are the Swiss VAT rates in 2026?', a: `The standard rate is ${normalPct}%, the reduced rate is ${reduzPct}%, and the special rate for accommodation is ${beherPct}%. These rates have been in effect since 01.01.2024.` },
  { q: 'Which goods have the reduced VAT rate?', a: 'Food (excluding alcohol and restaurant meals), medicine, newspapers, magazines, and books are taxed at the reduced rate. Tap water is also subject to the reduced rate.' },
  { q: 'How do I convert gross to net?', a: `Net amount = Gross amount / (1 + VAT rate). At the ${normalPct}% standard rate: Net = Gross / 1.081. Our calculator converts in both directions instantly.` },
  { q: 'Who must register for VAT?', a: 'Businesses with annual turnover of CHF 100,000 or more from taxable supplies are required to register. Voluntary registration is possible and can be worthwhile when input tax deductions are significant.' },
  { q: 'How does Swiss VAT compare to EU rates?', a: `At ${normalPct}%, Switzerland has one of Europe's lowest standard rates. Germany charges 19% (standard) and 7% (reduced). Switzerland also has a unique special rate for accommodation.` },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Swiss VAT Calculator 2026',
  url: 'https://loadouts.info/en/vat-calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'en',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://loadouts.info/en/' },
    { '@type': 'ListItem', position: 2, name: 'VAT Calculator', item: 'https://loadouts.info/en/vat-calculator' },
  ],
};

const glossaryEN = [
  { term: 'Value Added Tax (VAT)', definition: 'An indirect consumption tax on goods and services. Borne by the end consumer but remitted to the FTA by the business.' },
  { term: 'Standard rate', definition: `The default Swiss VAT rate, currently ${normalPct}%. Applies to most goods and services.` },
  { term: 'Reduced rate', definition: `The lower VAT rate of ${reduzPct}%. Applies to food, medicine, books, and newspapers.` },
  { term: 'Accommodation rate', definition: `A special rate of ${beherPct}% for overnight stays in hotels, guesthouses, and similar establishments.` },
  { term: 'Input tax deduction', definition: 'VAT-registered businesses may deduct the VAT paid on their purchases (input tax) from the VAT they owe on their sales.' },
];
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="vat-calculator" altSlug="mwst-rechner">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/en/" class="hover:text-[#1E3A8A]">Home</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">VAT Calculator</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Swiss VAT Calculator 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    Swiss <TermTooltip client:load term="Value Added Tax (VAT)" definition="An indirect consumption tax on goods and services. Borne by the end consumer." />
    has three rates: <strong>{normalPct}%</strong> standard,
    <strong>{reduzPct}%</strong> <TermTooltip client:load term="reduced rate" definition={`The lower VAT rate of ${reduzPct}% for food, medicine, books, and newspapers.`} />,
    and <strong>{beherPct}%</strong> for accommodation. Convert between net and gross amounts instantly.
  </p>

  <MwstRechner client:load lang="en" normal={CH2026.mwst.normal} reduziert={CH2026.mwst.reduziert} beherbergung={CH2026.mwst.beherbergung} />

  <div class="mt-12 bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-[#4B5563]">
    Calculations on loadouts.info are non-binding estimates and do not constitute financial, tax, or legal advice.
  </div>

  <SourceBox client:load federalSources={federalSources} lang="en" />

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <GlossarySection client:load entries={glossaryEN} lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
