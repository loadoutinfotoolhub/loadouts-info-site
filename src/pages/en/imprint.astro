---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Imprint | loadouts.info';
const description = 'Imprint of loadouts.info. Information according to Swiss law.';
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="imprint" altSlug="impressum" noindex={true}>
  <h1 class="text-3xl font-bold text-[#1E3A8A] mb-6">Imprint</h1>

  <div class="prose max-w-prose text-[#4B5563] space-y-4">
    <h2 class="text-xl font-semibold text-[#1E3A8A]">Operator</h2>
    <p>
      <strong>Name:</strong> NACHNAME_PLATZHALTER<br />
      <strong>Address:</strong> ADRESSE_PLATZHALTER<br />
      <strong>Email:</strong> feedback@loadouts.info
    </p>

    <h2 class="text-xl font-semibold text-[#1E3A8A]">Disclaimer</h2>
    <p>
      Calculations on loadouts.info are non-binding estimates and do not constitute financial, tax, or legal advice.
      loadouts.info assumes no liability for the accuracy, completeness, or timeliness of the information and calculations provided.
    </p>
    <p>
      Use of the calculators is at your own risk. For specific financial decisions, we recommend consulting a professional.
    </p>

    <h2 class="text-xl font-semibold text-[#1E3A8A]">Sources</h2>
    <p>
      All calculation bases come from official Swiss sources: Federal Social Insurance Office (BSV),
      Federal Tax Administration (ESTV), Swiss National Bank (SNB), FINMA and Swiss Bankers Association (SBA).
      Source citations are visible on each calculator page.
    </p>

    <h2 class="text-xl font-semibold text-[#1E3A8A]">Copyright</h2>
    <p>
      The contents of loadouts.info are protected by copyright. Any use beyond the limits of copyright law
      requires the prior written consent of the operator.
    </p>
  </div>
</BaseLayout>
