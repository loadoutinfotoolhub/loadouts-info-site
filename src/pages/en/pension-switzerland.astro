---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import { CH2026 } from '../../lib/ch-constants';

const title = 'Swiss Pension System: 3-Pillar System Explained 2026 | loadouts.info';
const description = 'Complete guide to Swiss retirement planning 2026. AHV, pension fund, pillar 3a. With calculators, examples and current figures.';

const fmt = (n: number) => new Intl.NumberFormat('de-CH').format(n);

const faqs = [
  { q: 'Are AHV and pension fund enough to live on?', a: `The maximum AHV pension in 2026 is CHF ${fmt(CH2026.ahvRenten.maxEinzelMonat)} per month. Together with pension fund, the target is 60% of last salary. For many, this is not enough to maintain their standard of living.` },
  { q: 'When should I start with pillar 3a?', a: `As early as possible. Each year you contribute the maximum of CHF ${fmt(CH2026.saeule3a.maxMitPK)} saves taxes and benefits from compound interest. Starting at 25 gives you 40 contribution years.` },
  { q: 'What happens to my pension if I emigrate?', a: 'AHV contribution years are preserved and you can receive the pension abroad. Pension fund becomes a vested benefits account. Pillar 3a can be withdrawn upon permanent departure.' },
  { q: 'How much should I contribute monthly to 3a?', a: `With pension fund: CHF 604.85/month (= ${fmt(CH2026.saeule3a.maxMitPK)} / 12). Monthly standing order from January maximises returns.` },
  { q: 'Is a pension fund buy-in worth it?', a: 'Yes, if you have gaps and a high marginal tax rate. The buy-in is fully tax-deductible. Note: 3-year lock-in before capital withdrawal.' },
  { q: 'Pension or lump sum: which is better?', a: 'Depends on your situation. Pension offers security and lifetime payments. Lump sum offers flexibility and can be inherited. Many choose a mix.' },
  { q: 'Can I use 3a to repay my mortgage?', a: 'Yes, indirect amortisation via pillar 3a is very popular in Switzerland. You contribute to 3a instead of paying the bank directly, save taxes, and amortise upon withdrawal.' },
  { q: 'Am I covered by a pension fund as self-employed?', a: `Not automatically. Self-employed can voluntarily join the BVG substitute institution. Without pension fund, the 3a maximum rises to 20% of net income (max CHF ${fmt(CH2026.saeule3a.maxOhnePK)}).` },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const articleSchema = { '@context': 'https://schema.org', '@type': 'Article', headline: title, datePublished: '2026-04-13', dateModified: '2026-04-13', author: { '@type': 'Organization', name: 'loadouts.info' }, publisher: { '@type': 'Organization', name: 'loadouts.info' } };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://loadouts.info/en/' }, { '@type': 'ListItem', position: 2, name: 'Pension Switzerland', item: 'https://loadouts.info/en/pension-switzerland' }] };

const federalSources = [
  { displayName: 'Federal Social Insurance Office (BSV)', url: 'https://www.bsv.admin.ch', legalBasis: 'OASI, BVG, BVV 3' },
  { displayName: 'AHV/IV Information Centre', url: 'https://www.ahv-iv.ch/en/Social-insurances' },
  { displayName: 'Fedlex: Federal Constitution Art. 111-113', url: 'https://www.fedlex.admin.ch/eli/cc/1999/404/de' },
  { displayName: 'Fedlex: BVG (Pension Fund Law)', url: 'https://www.fedlex.admin.ch/eli/cc/1983/797_797_797/de' },
];

const glossary = [
  { term: '3-Pillar System', definition: 'The Swiss pension system: state AHV (1st pillar), occupational pension fund (2nd pillar), and voluntary private savings (3rd pillar).' },
  { term: 'AHV (OASI)', definition: 'Old-age and survivors\' insurance. The state pension, financed on a pay-as-you-go basis. Mandatory for everyone in Switzerland.' },
  { term: 'BVG / Pension fund', definition: 'Occupational pension (2nd pillar). Mandatory for employees above a certain salary. Employer and employee contribute together.' },
  { term: 'Pillar 3a', definition: 'Tied private pension with tax deduction. Max 2026: CHF 7\'258 (with PF) or CHF 36\'288 (without PF).' },
  { term: 'Coordination deduction', definition: 'Amount deducted from salary before BVG calculation (2026: CHF 26\'460), as AHV already covers part of retirement.' },
  { term: 'Conversion rate', definition: 'Percentage converting pension capital into annual pension. BVG minimum: 6.8%.' },
  { term: 'Pension gap', definition: 'The shortfall between your last salary and expected pensions from AHV + PF. Must be closed with 3rd pillar or savings.' },
];
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="pension-switzerland" altSlug="vorsorge-schweiz">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/en/" class="hover:text-[#1E3A8A]">Home</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Pension Switzerland</span>
  </nav>

  <article class="max-w-prose">
    <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-6 leading-tight">Swiss Pension System: Complete Guide 2026</h1>

    <p class="text-lg text-[#4B5563] mb-6 leading-relaxed">
      The Swiss pension system has been based on three pillars since 1972: the state AHV (1st pillar) for basic needs, the occupational BVG pension fund (2nd pillar) to maintain living standards, and voluntary private savings (3rd pillar). In 2026, the maximum single AHV pension is CHF {fmt(CH2026.ahvRenten.maxEinzelMonat)} per month, and the pillar 3a maximum with pension fund is CHF {fmt(CH2026.saeule3a.maxMitPK)}.
    </p>

    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">The 3-Pillar System at a Glance</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Enshrined in the Federal Constitution since 1972 (Art. 111), the system distributes retirement provision across state, employer, and personal responsibility. The target: AHV and pension fund together should replace 60% of your last salary. The 3rd pillar closes the remaining gap.
    </p>

    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">1st Pillar: AHV (State Pension)</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      The AHV covers basic living costs in retirement. It is mandatory for all residents and workers in Switzerland from age 18. In 2026, the minimum single pension is CHF {fmt(CH2026.ahvRenten.minEinzelMonat)}/month, maximum CHF {fmt(CH2026.ahvRenten.maxEinzelMonat)}/month. Married couples receive max CHF {fmt(CH2026.ahvRenten.maxEhepaarMonat)}.
      <a href="/en/salary-calculator" class="text-[#1E3A8A] underline">Our salary calculator</a> shows your AHV deductions.
    </p>

    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">2nd Pillar: Pension Fund (BVG)</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Mandatory for employees earning above CHF {fmt(CH2026.bvg.eintrittsschwelle)}/year. Contribution rates increase with age: {(CH2026.bvg.beitragssaetze['25_34'] * 100).toFixed(0)}% (25-34), {(CH2026.bvg.beitragssaetze['35_44'] * 100).toFixed(0)}% (35-44), {(CH2026.bvg.beitragssaetze['45_54'] * 100).toFixed(0)}% (45-54), {(CH2026.bvg.beitragssaetze['55_65'] * 100).toFixed(0)}% (55-65). The BVG minimum conversion rate is {(CH2026.bvg.umwandlungssatz * 100).toFixed(1)}%.
    </p>

    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">3rd Pillar: Private Savings (3a and 3b)</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      Voluntary and tax-advantaged. Pillar 3a contributions are fully deductible: max CHF {fmt(CH2026.saeule3a.maxMitPK)} with pension fund, CHF {fmt(CH2026.saeule3a.maxOhnePK)} without. New from 2026: retroactive contributions possible for gaps from 2025 onwards.
      <a href="/en/pillar-3a-calculator" class="text-[#1E3A8A] underline font-medium">Calculate your pillar 3a savings now</a>.
    </p>

    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">Identifying and Closing Pension Gaps</h2>
    <p class="text-[#4B5563] mb-4 leading-relaxed">
      A pension gap arises when AHV + pension fund cover less than 60-70% of your last salary. Common causes: part-time work, career breaks, time abroad, low pension contributions, early retirement. Close the gap with: pillar 3a, pension fund buy-ins, working longer, free savings, or property.
    </p>

    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-6">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>

    <h2 class="text-2xl font-semibold text-[#1E3A8A] mt-10 mb-4">Your Next Steps</h2>
    <div class="grid sm:grid-cols-2 gap-3 mb-8">
      <a href="/en/pillar-3a-calculator" class="block bg-[#059669] text-white rounded-lg p-4 hover:bg-[#047857] transition-colors font-medium text-center">Start Pillar 3a Calculator</a>
      <a href="/en/salary-calculator" class="block bg-[#1E3A8A] text-white rounded-lg p-4 hover:bg-[#1E3070] transition-colors font-medium text-center">Calculate Salary & Deductions</a>
      <a href="/en/mortgage-affordability" class="block bg-white border border-[#1E3A8A] text-[#1E3A8A] rounded-lg p-4 hover:bg-blue-50 transition-colors font-medium text-center">Check Mortgage Affordability</a>
      <a href="/en/saron-mortgage-calculator" class="block bg-white border border-[#1E3A8A] text-[#1E3A8A] rounded-lg p-4 hover:bg-blue-50 transition-colors font-medium text-center">Calculate SARON Mortgage</a>
    </div>
  </article>

  <SourceBox client:load federalSources={federalSources} lang="en" />
  <GlossarySection client:load entries={glossary} lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
