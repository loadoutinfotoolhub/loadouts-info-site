---
import { getCollection } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import ItemGrid from '@/components/sections/ItemGrid.astro';
import CharacterView from '@/components/character/CharacterView.astro';
import MobileInventoryList from '@/components/ui/MobileInventoryList.astro';
import SummaryBar from '@/components/ui/SummaryBar.astro';
import TierBadge from '@/components/ui/TierBadge.astro';
import TierLadder from '@/components/ui/TierLadder.astro';
import RelatedLoadouts from '@/components/sections/RelatedLoadouts.astro';
import ShareButton from '@/components/ui/ShareButton.svelte';
import ViewToggle from '@/components/ui/ViewToggle.svelte';
import Icon from '@/components/ui/Icon.astro';
import { ui } from '@/data/i18n';
import { findKategorie } from '@/data/kategorien';
import { tiers, tierOrder } from '@/data/tiers';

export async function getStaticPaths() {
  const all = await getCollection('loadouts');
  return all.map((l) => ({
    params: { slug: l.data.slug },
    props: { loadout: l, all },
  }));
}

const { loadout, all } = Astro.props;
const data = loadout.data;
const t = ui.en;
const kategorie = findKategorie(data.kategorie_slug);
const canonical = `https://loadouts.info/en/loadouts/${data.slug}`;
const total = data.items.reduce((s, i) => s + i.price_chf, 0);

const currentTierIdx = tierOrder.indexOf(data.tier);
const nextTierKey = currentTierIdx >= 0 && currentTierIdx < tierOrder.length - 1
  ? tierOrder[currentTierIdx + 1]
  : null;
const nextLoadout = nextTierKey
  ? all.find((l) => l.data.kategorie_slug === data.kategorie_slug && l.data.tier === nextTierKey)
  : null;
const nextTierLabel = nextLoadout ? tiers[nextTierKey!].label_en : null;
const nextTierHref  = nextLoadout ? `/en/loadouts/${nextLoadout.data.slug}` : null;
const nextTierTotal = nextLoadout ? nextLoadout.data.items.reduce((s, i) => s + i.price_chf, 0) : null;
const nextTierDiff  = nextTierTotal != null ? Math.max(0, Math.round(nextTierTotal - total)) : null;

const categoryLabel = kategorie?.name_en ?? '';
const categoryHref  = kategorie ? `/en/category/${kategorie.slug}` : '';

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: data.name_en,
  description: data.description_en,
  numberOfItems: data.items.length,
  itemListElement: data.items.map((it, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    name: it.name_en,
    url: `https://loadouts.info/go/${it.go_slug}`,
  })),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t.breadcrumb_home, item: 'https://loadouts.info/en/' },
    kategorie && {
      '@type': 'ListItem',
      position: 2,
      name: kategorie.name_en,
      item: `https://loadouts.info/en/category/${kategorie.slug}`,
    },
    { '@type': 'ListItem', position: 3, name: data.name_en, item: canonical },
  ].filter(Boolean),
};
---
<BaseLayout
  lang="en"
  title={data.seo.title_en}
  description={data.seo.desc_en}
  canonical={canonical}
  dePath={`/de/loadouts/${data.slug}`}
  enPath={`/en/loadouts/${data.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <div class="wrap">
    <nav class="crumbs" aria-label="breadcrumb">
      <a href="/en/">{t.breadcrumb_home}</a>
      {kategorie && (
        <>
          <Icon name="chevron-right" size={12} />
          <a href={`/en/category/${kategorie.slug}`}>{kategorie.name_en}</a>
        </>
      )}
      <Icon name="chevron-right" size={12} />
      <span>{data.name_en}</span>
    </nav>

    <header class="lh">
      {kategorie && (
        <span class="lh-icon" aria-hidden="true">
          <Icon name={kategorie.icon} size={28} />
        </span>
      )}
      <div class="lh-meta">
        <TierBadge tier={data.tier} lang="en" />
        <span class="lh-proof">{data.social_proof} {t.social_proof_suffix}</span>
      </div>
      <h1>{data.name_en}</h1>
      <p class="lh-desc">{data.description_en}</p>
    </header>

    <TierLadder currentTier={data.tier} lang="en" />

    {data.hat_character_view && data.equipment_slots && (
      <div class="view-controls">
        <ViewToggle
          client:load
          gridLabel={t.view_grid}
          equipmentLabel={t.view_equipment}
          targetId={`view-${data.slug}`}
        />
      </div>
    )}

    <div id={`view-${data.slug}`} class:list={['view-container', data.hat_character_view && 'has-character']} data-view={data.hat_character_view && data.equipment_slots ? 'equipment' : 'grid'}>
      <div class="view-grid">
        <ItemGrid items={data.items} tier={data.tier} lang="en" />
      </div>
      {data.hat_character_view && data.equipment_slots && (
        <div class="view-equipment">
          <CharacterView
            items={data.items}
            equipmentSlots={data.equipment_slots}
            lang="en"
            description={data.description_en}
            totalPrice={total}
            categoryLabel={categoryLabel}
            categoryHref={categoryHref}
          />
          {(() => {
            const slotted = new Set(Object.values(data.equipment_slots));
            const overflow = data.items.filter((i) => !slotted.has(i.id));
            return overflow.length > 0 ? (
              <section class="overflow">
                <h2>More Equipment</h2>
                <ItemGrid items={overflow} tier={data.tier} lang="en" />
              </section>
            ) : null;
          })()}
        </div>
      )}
    </div>

    {data.hat_character_view && (
      <div class="mobile-inventory">
        <MobileInventoryList items={data.items} lang="en" />
      </div>
    )}

    <SummaryBar
      total={total}
      itemCount={data.items.length}
      lang="en"
      nextTierHref={nextTierHref}
      nextTierLabel={nextTierLabel}
      nextTierDiff={nextTierDiff}
    />

    <RelatedLoadouts slugs={data.related_slugs} lang="en" />

    <div class="share-row">
      <ShareButton client:visible url={canonical} title={data.name_en} shareLabel={t.share} copiedLabel={t.share_copied} />
    </div>
  </div>
</BaseLayout>

<style>
  .wrap { max-width: 1200px; margin: 0 auto; padding: var(--space-8) var(--space-4); }
  .crumbs { font-size: 0.85rem; color: var(--text-muted); margin-bottom: var(--space-4); display: inline-flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .crumbs a { color: var(--text-secondary); }
  .crumbs a:hover { color: var(--text-primary); }
  .lh { text-align: center; padding: var(--space-6) 0 var(--space-8); }
  .lh-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: var(--bg-elevated);
    border-radius: 50%;
    color: var(--accent);
  }
  .lh-meta { display: inline-flex; gap: 10px; align-items: center; margin: 12px 0 10px; color: var(--text-muted); font-size: 0.85rem; }
  .lh h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-3xl);
    letter-spacing: -0.03em;
    margin: 10px 0;
  }
  .lh-desc { color: var(--text-secondary); max-width: 640px; margin: 0 auto; line-height: 1.6; }
  .view-controls { margin: var(--space-6) 0 var(--space-4); display: flex; justify-content: flex-end; }
  .view-container { margin-top: var(--space-4); }
  .view-container[data-view="grid"] .view-equipment { display: none; }
  .view-container[data-view="equipment"] .view-grid { display: none; }
  .mobile-inventory { display: none; margin-top: var(--space-4); }
  @media (max-width: 768px) {
    .view-controls { display: none; }
    .view-container.has-character { display: none; }
    .mobile-inventory { display: block; }
  }
  .share-row { margin-top: var(--space-8); display: flex; justify-content: center; }
  .overflow { margin-top: var(--space-6); }
  .overflow h2 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 0 0 var(--space-3);
    color: var(--text-primary);
  }
</style>
