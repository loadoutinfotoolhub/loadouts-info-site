---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Lohnrechner from '../../components/calculators/Lohnrechner.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';
import { CH2026 } from '../../lib/ch-constants';

const title = 'Swiss Salary Calculator 2026: Net from Gross | loadouts.info';
const description = 'Calculate your Swiss net salary from gross. All deductions: AHV, IV, EO, ALV, pension, taxes. 7 cantons, free.';

const federalSources = [
  { displayName: 'Federal Social Insurance Office (BSV)', url: 'https://www.bsv.admin.ch/de/beitraege-im-ueberblick', legalBasis: 'AHVG, IVG, EOG' },
  { displayName: 'State Secretariat for Economic Affairs (SECO)', url: 'https://www.seco.admin.ch', legalBasis: 'AVIG Art. 3' },
  { displayName: 'AHV/IV Information Centre', url: 'https://www.ahv-iv.ch/en/Social-insurances' },
  { displayName: 'Fedlex: BVG (Federal Law)', url: 'https://www.fedlex.admin.ch/eli/cc/1983/797_797_797/de' },
];

const faqs = [
  { q: 'What deductions are taken from my gross salary?', a: `Standard 2026: AHV ${(CH2026.sozialversicherung.ahv * 100).toFixed(1)}%, IV ${(CH2026.sozialversicherung.iv * 100).toFixed(1)}%, EO ${(CH2026.sozialversicherung.eo * 100).toFixed(2)}%, ALV ${(CH2026.sozialversicherung.alv * 100).toFixed(1)}% (up to CHF ${new Intl.NumberFormat('de-CH').format(CH2026.sozialversicherung.alvMaxEinkommen)}), pension fund (varies, typically 7%), and income tax.` },
  { q: 'How much net from CHF 100,000 gross?', a: 'For a single, 30-year-old, no church tax: approx. CHF 75,000 to 82,000 net, depending on the canton. Much more in Zug than in Geneva.' },
  { q: 'What is the 13th salary?', a: 'A voluntary additional monthly payment from employers, usually in November or December. Not legally required, but common in most Swiss employment contracts.' },
  { q: 'How is the pension fund calculated?', a: `From an annual salary of CHF ${new Intl.NumberFormat('de-CH').format(CH2026.bvg.eintrittsschwelle)} (BVG threshold 2026), a pension contribution applies. Rate depends on age: 7% (25-34), 10% (35-44), 15% (45-54), 18% (55-65). Employer and employee typically split 50/50.` },
  { q: 'What is the coordination deduction?', a: `CHF ${new Intl.NumberFormat('de-CH').format(CH2026.bvg.koordinationsabzug)} (2026) is deducted before calculating pension contributions. Only salary above this amount up to CHF ${new Intl.NumberFormat('de-CH').format(CH2026.bvg.maxVersLohn)} is covered by mandatory BVG.` },
  { q: 'Do I have to pay church tax?', a: 'Only if you are a member of a recognized church (Catholic, Protestant). You can leave, and the church tax drops away. The surcharge is 6-12% on cantonal tax.' },
  { q: 'What is the marginal tax rate?', a: 'The tax rate applied to the last franc of your income. Important for pillar 3a: every franc contributed saves exactly this percentage in taxes.' },
  { q: 'What is the median salary in Switzerland?', a: 'According to the Federal Statistical Office (BFS), the median salary is about CHF 85,000 gross per year (full-time).' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Swiss Salary Calculator 2026',
  url: 'https://loadouts.info/en/salary-calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'en',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://loadouts.info/en/' },
    { '@type': 'ListItem', position: 2, name: 'Salary Calculator', item: 'https://loadouts.info/en/salary-calculator' },
  ],
};

const glossaryEN = [
  { term: 'Gross salary', definition: 'Your salary before any deductions. The amount stated in your employment contract.' },
  { term: 'Net salary', definition: 'What actually arrives in your bank account after all deductions.' },
  { term: 'AHV', definition: 'Old-age and survivors\' insurance, the state pension (1st pillar). Mandatory contribution: 5.3%.' },
  { term: 'IV', definition: 'Disability insurance. Covers permanent incapacity to work. Contribution: 0.7%.' },
  { term: 'EO', definition: 'Income replacement scheme. Funds compensation during military service and maternity. Contribution: 0.25%.' },
  { term: 'ALV', definition: 'Unemployment insurance. Covers income loss if you lose your job. Contribution: 1.1% up to an income cap.' },
  { term: 'BVG / Pension fund', definition: 'Occupational pension (2nd pillar). Mandatory above a salary of CHF 22,680. Rate increases with age.' },
  { term: 'Marginal tax rate', definition: 'The tax rate on the last franc earned. Determines how much tax you save per franc contributed to pillar 3a.' },
  { term: 'Coordination deduction', definition: 'Amount subtracted from gross salary before calculating pension contributions. Accounts for AHV already covering part of retirement.' },
  { term: '13th salary', definition: 'An extra monthly payment per year, typical in Swiss employment contracts. Not legally required.' },
];
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="salary-calculator" altSlug="lohnrechner">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/en/" class="hover:text-[#1E3A8A]">Home</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Salary Calculator</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Swiss Salary Calculator 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    In Switzerland, your <TermTooltip client:load term="gross salary" definition="Your salary before any deductions, as stated in your contract." />
    is reduced by social insurance contributions (<TermTooltip client:load term="AHV" definition="Old-age and survivors' insurance, the Swiss state pension (1st pillar)." /> 5.3%,
    IV 0.7%, EO 0.25%, ALV 1.1%), <TermTooltip client:load term="pension fund" definition="Occupational pension (2nd pillar). Rate increases with age." /> contributions,
    and income tax. From CHF 85,000 gross, expect about CHF 65,000 to 72,000 net depending on your canton.
  </p>

  <Lohnrechner client:load lang="en" />

  <p class="mt-6 text-sm text-[#4B5563] italic">
    Calculations on loadouts.info are non-binding estimates and do not constitute financial, tax, or legal advice.
  </p>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <SourceBox client:load federalSources={federalSources} lang="en" />

  <GlossarySection client:load entries={glossaryEN} lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
