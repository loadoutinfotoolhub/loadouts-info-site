---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Saeule3a from '../../components/calculators/Saeule3a.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import { CH2026, CH2026Sourced } from '../../lib/ch-constants';

const title = 'Pillar 3a Calculator 2026: Maximum Amount & Tax Savings | loadouts.info';
const description = 'Calculate your Swiss pillar 3a maximum contribution and tax savings for 2026. Free, no registration. All cantons.';

const federalSources = [
  { displayName: 'Federal Social Insurance Office (BSV)', url: CH2026Sourced.saeule3a.maxMitPK.source.url, legalBasis: CH2026Sourced.saeule3a.maxMitPK.source.legalBasis },
  { displayName: 'Fedlex - BVV 3 (Ordinance)', url: 'https://www.fedlex.admin.ch/eli/cc/1985/2_2_2/de' },
  { displayName: 'AHV/IV Information Centre', url: 'https://www.ahv-iv.ch/en/Social-insurances' },
];

const faqs = [
  { q: 'How much can I contribute to pillar 3a in 2026?', a: `With a pension fund: max CHF ${new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxMitPK)}. Without a pension fund: max 20% of net income or CHF ${new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxOhnePK)} (whichever is lower). Source: BSV, BVV 3.` },
  { q: 'When is the deadline for 2026 contributions?', a: 'Contributions for tax year 2026 must arrive in your pillar 3a account by December 31, 2026. Many providers recommend contributing by mid-December to ensure timely processing.' },
  { q: 'How much tax can I save with a maximum 3a contribution?', a: `Tax savings depend on your marginal tax rate. Typically CHF 1,500 to 2,500 per year with a maximum contribution of CHF ${new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxMitPK)}. Savings are higher in high-tax cantons (e.g. GE, VD) and lower in ZG or SZ.` },
  { q: 'Can I make retroactive contributions?', a: 'Yes, from 2026 retroactive contributions are possible for the first time, but only for gaps from 2025 onwards. You can contribute retroactively for up to 10 years, max CHF 7,258 per gap year.' },
  { q: 'Should I contribute monthly or annually?', a: 'A January lump-sum contribution maximises returns as the money is invested all year. A monthly standing order of CHF 604.85 (= 7,258 / 12) provides better liquidity planning. Both are taxed equally.' },
  { q: 'What happens if I overpay?', a: 'Amounts above the maximum are not tax-deductible. Many providers automatically reject overpayments. If you have multiple 3a accounts, all contributions count together.' },
  { q: 'When can I withdraw my 3a assets?', a: 'Earliest 5 years before reference age (from age 60). Early withdrawal only for home purchase, self-employment, or emigration. Withdrawals are taxed at a reduced rate.' },
  { q: 'Is pillar 3a worth it for me?', a: 'Almost always yes if you have AHV-liable income and pay taxes. The higher your income and marginal tax rate, the greater the benefit.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Pillar 3a Calculator 2026',
  url: 'https://loadouts.info/en/pillar-3a-calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'All',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' },
  inLanguage: 'en',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://loadouts.info/en/' },
    { '@type': 'ListItem', position: 2, name: 'Pillar 3a Calculator', item: 'https://loadouts.info/en/pillar-3a-calculator' },
  ],
};
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="pillar-3a-calculator" altSlug="saeule-3a-rechner">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/en/" class="hover:text-[#1E3A8A]">Home</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Pillar 3a Calculator</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Pillar 3a Calculator 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    Pillar 3a is Switzerland's private, tax-advantaged retirement savings plan. In 2026, you can contribute up to
    <strong>CHF {new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxMitPK)}</strong> if you belong to a pension fund.
    Without a pension fund, you can deduct up to <strong>20% of your net earned income</strong>,
    max <strong>CHF {new Intl.NumberFormat('de-CH').format(CH2026.saeule3a.maxOhnePK)}</strong>.
  </p>

  <Saeule3a client:load lang="en" maxMitPK={CH2026.saeule3a.maxMitPK} maxOhnePK={CH2026.saeule3a.maxOhnePK} />

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <SourceBox client:load federalSources={federalSources} lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
