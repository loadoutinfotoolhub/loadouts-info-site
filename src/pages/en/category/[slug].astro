---
import { getCollection } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import TierComparison from '@/components/sections/TierComparison.astro';
import TierBadge from '@/components/ui/TierBadge.astro';
import Icon from '@/components/ui/Icon.astro';
import { kategorien } from '@/data/kategorien';
import { ui } from '@/data/i18n';

export async function getStaticPaths() {
  const all = await getCollection('loadouts');
  return kategorien.map((k) => ({
    params: { slug: k.slug },
    props: {
      kategorie: k,
      loadouts: all.filter((l) => l.data.kategorie_slug === k.slug),
    },
  }));
}

const { kategorie, loadouts } = Astro.props;
const t = ui.en;
const canonical = `https://loadouts.info/en/category/${kategorie.slug}`;
const loadoutPrefix = '/en/loadouts/';
---
<BaseLayout
  lang="en"
  title={`${kategorie.name_en} — The right setups | loadouts.info`}
  description={kategorie.desc_en}
  canonical={canonical}
  dePath={`/de/kategorie/${kategorie.slug}`}
  enPath={`/en/category/${kategorie.slug}`}
>
  <div class="wrap">
    <nav class="crumbs" aria-label="breadcrumb">
      <a href="/en/">{t.breadcrumb_home}</a>
      <Icon name="chevron-right" size={12} />
      <span>{kategorie.name_en}</span>
    </nav>

    <header class="cat-head">
      <span class="cat-icon" aria-hidden="true">
        <Icon name={kategorie.icon} size={30} />
      </span>
      <h1>{kategorie.name_en}</h1>
      <p>{kategorie.desc_en}</p>
    </header>

    <TierComparison loadouts={loadouts} lang="en" />

    <section class="list">
      <h2>All setups in {kategorie.name_en}</h2>
      <div class="grid">
        {loadouts.map((l) => (
          <a class="card" href={`${loadoutPrefix}${l.data.slug}`}>
            <div class="card-head">
              <span class="card-icon" aria-hidden="true">
                <Icon name={kategorie.icon} size={18} />
              </span>
              <TierBadge tier={l.data.tier} lang="en" />
            </div>
            <h3>{l.data.name_en}</h3>
            <p>{l.data.description_en}</p>
            <div class="card-foot">
              <span class="card-total">CHF {l.data.items.reduce((s, i) => s + i.price_chf, 0)}</span>
              <span class="card-arrow"><Icon name="arrow-right" size={14} /></span>
            </div>
          </a>
        ))}
        {loadouts.length === 0 && <p class="empty">Coming soon.</p>}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .wrap { max-width: 1180px; margin: 0 auto; padding: var(--space-8) var(--space-4); }
  .crumbs {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .crumbs a { color: var(--text-secondary); }
  .crumbs a:hover { color: var(--text-primary); }

  .cat-head { text-align: center; padding: var(--space-8) 0; display: flex; flex-direction: column; align-items: center; gap: var(--space-3); }
  .cat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: var(--bg-elevated);
    border-radius: 50%;
    color: var(--accent);
  }
  .cat-head h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-3xl);
    letter-spacing: -0.03em;
    margin: 0;
  }
  .cat-head p { color: var(--text-secondary); max-width: 600px; margin: 0; }

  .list { margin-top: var(--space-8); }
  h2 {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin: 0 0 var(--space-4);
    letter-spacing: -0.02em;
  }
  .grid { display: grid; gap: var(--space-4); grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
  .card {
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-card);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    box-shadow: var(--card-shadow);
    transition: border-color .15s, transform .15s, box-shadow .2s;
  }
  .card:hover {
    border-color: var(--border-default);
    transform: translateY(-2px);
    box-shadow: var(--card-shadow-hover);
  }
  .card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-2); }
  .card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: var(--bg-elevated);
    border-radius: var(--radius-btn);
    color: var(--accent);
  }
  .card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .card p { color: var(--text-secondary); font-size: 0.9rem; margin: 0; line-height: 1.5; }
  .card-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: var(--space-2);
  }
  .card-total {
    font-family: var(--font-mono);
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .card-arrow { color: var(--text-muted); }
  .card:hover .card-arrow { color: var(--accent); }
  .empty { color: var(--text-muted); }
</style>
