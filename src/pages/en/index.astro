---
import { getCollection } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import WhatIsLoadout from '@/components/sections/WhatIsLoadout.astro';
import CategoryGrid from '@/components/sections/CategoryGrid.astro';
import FeaturedLoadout from '@/components/sections/FeaturedLoadout.astro';
import HowItWorks from '@/components/sections/HowItWorks.astro';

const all = await getCollection('loadouts');
const featured = all.find((l) => l.data.slug === 'hyrox-beginner') ?? all[0];
---
<BaseLayout
  lang="en"
  title="loadouts.info — The right setup for your hobby, your sport, your life"
  description="We show you exactly what gear you need — as a beginner, intermediate or pro. Clearly structured, honestly reviewed."
  canonical="https://loadouts.info/en/"
  dePath="/de/"
  enPath="/en/"
>
  <HeroSection lang="en" />
  <WhatIsLoadout lang="en" />
  <CategoryGrid lang="en" />
  {featured && <FeaturedLoadout loadout={featured} lang="en" />}
  <HowItWorks lang="en" />
</BaseLayout>
