---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Tragbarkeit from '../../components/calculators/Tragbarkeit.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';

const title = 'Swiss Mortgage Affordability Calculator 2026 | loadouts.info';
const description = 'Check if your income supports a Swiss mortgage. Imputed interest, down payment, amortisation calculated. Free.';

const federalSources = [
  { displayName: 'FINMA / Swiss Bankers Association', url: 'https://www.finma.ch/en/documentation/dossier/dossier-hypothekarmarkt/', legalBasis: 'SBA Guidelines Minimum Requirements Mortgage Financing' },
  { displayName: 'Fedlex: BVG (Home ownership withdrawal)', url: 'https://www.fedlex.admin.ch/eli/cc/1983/797_797_797/de' },
];

const faqs = [
  { q: 'How much mortgage can I afford?', a: 'Rule of thumb: Your gross income must be at least 3x the annual housing costs. For a CHF 800,000 mortgage at 5% imputed rate, you need about CHF 175,000 gross income.' },
  { q: 'Why does the bank use 5% interest?', a: 'The 5% imputed rate is a FINMA/SBA guideline. It protects you and the bank against interest rate hikes. Even with current rates at 1-2%, affordability is calculated at 5%.' },
  { q: 'How much down payment do I need?', a: 'At least 20% of the purchase price. Of that, 10% must be hard equity (savings, securities). The other 10% can come from pension fund or pillar 3a.' },
  { q: 'What is amortisation?', a: 'Repaying the mortgage. In Switzerland, the mortgage must be reduced to two-thirds of the property value within 15 years.' },
  { q: 'What are typical maintenance costs?', a: 'Banks assume about 1% of property value per year for maintenance, plus heating, electricity, and insurance.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const appSchema = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'Swiss Mortgage Affordability Calculator 2026', url: 'https://loadouts.info/en/mortgage-affordability', applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' }, inLanguage: 'en' };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://loadouts.info/en/' }, { '@type': 'ListItem', position: 2, name: 'Mortgage Affordability', item: 'https://loadouts.info/en/mortgage-affordability' }] };

const glossaryEN = [
  { term: 'Affordability', definition: 'Test whether your income supports the mortgage long-term. Housing costs must not exceed 33% of gross income.' },
  { term: 'Imputed interest rate', definition: 'A theoretical 5% rate banks use for affordability calculations. Protects against future rate increases.' },
  { term: 'Amortisation', definition: 'Repaying the mortgage. The 2nd mortgage (above 66% LTV) must be repaid within 15 years.' },
  { term: 'Down payment', definition: 'Your own funds in a property purchase. Minimum 20% of price, with 10% from hard equity.' },
  { term: '1st mortgage', definition: 'Finances up to 66% of property value. Does not need to be amortised.' },
  { term: '2nd mortgage', definition: 'Finances 66-80% of property value. Must be repaid within 15 years.' },
  { term: 'Loan-to-value (LTV)', definition: 'Percentage of property value financed by the mortgage. Maximum 80%.' },
  { term: 'Maintenance allowance', definition: 'Annual costs for upkeep and repairs. Banks assume about 1% of property value.' },
];
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="mortgage-affordability" altSlug="hypothek-tragbarkeit">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/en/" class="hover:text-[#1E3A8A]">Home</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">Mortgage Affordability</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">Mortgage Affordability Calculator 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    A Swiss mortgage is <TermTooltip client:load term="affordable" definition="Housing costs must not exceed 33% of your gross income." />
    when housing costs stay below 33% of your gross income. Banks use an
    <TermTooltip client:load term="imputed interest rate" definition="A theoretical 5% rate used to protect against future rate increases." /> of 5%.
    You need at least 20% <TermTooltip client:load term="down payment" definition="Your own funds. 10% must be hard equity (savings), 10% can be from pension." />.
  </p>

  <Tragbarkeit client:load lang="en" />

  <p class="mt-6 text-sm text-[#4B5563] italic">
    Calculations on loadouts.info are non-binding estimates and do not constitute financial, tax, or legal advice.
  </p>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <SourceBox client:load federalSources={federalSources} lang="en" />
  <GlossarySection client:load entries={glossaryEN} lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
