---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SaronHypothek from '../../components/calculators/SaronHypothek.svelte';
import SourceBox from '../../components/blocks/SourceBox.svelte';
import TermTooltip from '../../components/ui/TermTooltip.svelte';
import GlossarySection from '../../components/blocks/GlossarySection.svelte';

const title = 'SARON Mortgage Calculator 2026: Rates, Scenarios, Comparison | loadouts.info';
const description = 'Calculate your SARON mortgage: monthly payment, comparison with fixed rate, stress test. Current rates, free.';

const federalSources = [
  { displayName: 'Swiss National Bank (SNB)', url: 'https://www.snb.ch/en/the-saron/saron-rate', legalBasis: 'SARON reference rate' },
  { displayName: 'SNB Interest Rate Data', url: 'https://data.snb.ch/en/topics/ziredev/chart/zimoma' },
  { displayName: 'FINMA / Swiss Bankers Association', url: 'https://www.finma.ch/en/documentation/dossier/dossier-hypothekarmarkt/' },
];

const faqs = [
  { q: 'What is SARON?', a: 'SARON stands for Swiss Average Rate Overnight. It is Switzerland\'s official reference rate, calculated from repo transactions by the SNB. SARON mortgages tie their rate to this value plus a bank margin.' },
  { q: 'SARON or fixed-rate: which is better?', a: 'SARON has been cheaper most of the past 15 years. Fixed-rate offers planning certainty. If you can handle rate increases, SARON often saves money.' },
  { q: 'Can SARON go negative?', a: 'Yes, historically it was negative (2015-2022). Usually a floor of 0% applies, so you only pay the bank margin.' },
  { q: 'How often is the rate adjusted?', a: 'Typically quarterly. The compounded SARON rate is calculated and charged every 3 months.' },
  { q: 'How do I hedge against rate increases?', a: 'Options: mix of SARON and fixed-rate, cap agreement with bank, or switch to fixed when rates rise.' },
];

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const appSchema = { '@context': 'https://schema.org', '@type': 'WebApplication', name: 'SARON Mortgage Calculator 2026', url: 'https://loadouts.info/en/saron-mortgage-calculator', applicationCategory: 'FinanceApplication', operatingSystem: 'All', offers: { '@type': 'Offer', price: '0', priceCurrency: 'CHF' }, inLanguage: 'en' };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [{ '@type': 'ListItem', position: 1, name: 'Home', item: 'https://loadouts.info/en/' }, { '@type': 'ListItem', position: 2, name: 'SARON Mortgage', item: 'https://loadouts.info/en/saron-mortgage-calculator' }] };

const glossaryEN = [
  { term: 'SARON', definition: 'Swiss Average Rate Overnight. Switzerland\'s official reference rate, calculated from repo transactions and published daily by the SNB.' },
  { term: 'Compounded SARON', definition: 'The accumulated SARON over a period (e.g. 3 months). Used for interest calculations on SARON mortgages.' },
  { term: 'Bank margin', definition: 'The markup the bank charges on top of SARON. Typically 0.6% to 1.0%. Better creditworthiness means lower margin.' },
  { term: 'Fixed-rate mortgage', definition: 'Mortgage with a fixed interest rate over a set period (e.g. 5 or 10 years). Offers certainty but usually costs more than SARON.' },
  { term: 'Benchmark rate', definition: 'A reference rate that variable mortgage rates follow. In Switzerland, SARON is the official benchmark.' },
  { term: 'Stress test', definition: 'Calculation showing what happens if rates rise sharply. Banks check if you can still afford the mortgage at 5% interest.' },
];
---
<BaseLayout title={title} description={description} lang="en" canonicalSlug="saron-mortgage-calculator" altSlug="saron-hypothek-rechner">
  <nav class="text-sm text-[#4B5563] mb-6" aria-label="Breadcrumb">
    <a href="/en/" class="hover:text-[#1E3A8A]">Home</a>
    <span class="mx-1">/</span>
    <span class="text-[#1E3A8A] font-medium">SARON Mortgage</span>
  </nav>

  <h1 class="text-3xl md:text-4xl font-bold text-[#1E3A8A] mb-4">SARON Mortgage Calculator 2026</h1>

  <p class="text-lg text-[#4B5563] mb-8 max-w-prose leading-relaxed">
    A <TermTooltip client:load term="SARON mortgage" definition="Variable mortgage whose rate is tied to the Swiss Average Rate Overnight." />
    is a variable mortgage tied to the <TermTooltip client:load term="SARON" definition="Swiss Average Rate Overnight, Switzerland's official reference rate from the SNB." />.
    With a current SARON of about 0.2-0.5% and a
    <TermTooltip client:load term="bank margin" definition="The bank's markup on SARON, typically 0.6-1.0%." /> of 0.6-1.0%,
    total costs are around 1-1.5% per year.
  </p>

  <SaronHypothek client:load lang="en" />

  <p class="mt-6 text-sm text-[#4B5563] italic">
    Calculations on loadouts.info are non-binding estimates and do not constitute financial, tax, or legal advice.
  </p>

  <section class="mt-12">
    <h2 class="text-2xl font-semibold text-[#1E3A8A] mb-6">Frequently Asked Questions</h2>
    <div class="space-y-6">
      {faqs.map(faq => (
        <details class="bg-white rounded-lg border border-gray-200 p-4 group">
          <summary class="font-medium text-[#1E3A8A] cursor-pointer list-none flex items-center justify-between">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 text-[#4B5563] transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-[#4B5563] leading-relaxed">{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <SourceBox client:load federalSources={federalSources} lang="en" />
  <GlossarySection client:load entries={glossaryEN} lang="en" />

  <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
