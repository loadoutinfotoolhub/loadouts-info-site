---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('loadouts');
  const paths: { params: { slug: string }; props: { target: string } }[] = [];
  const seen = new Set<string>();
  for (const l of all) {
    for (const it of l.data.items) {
      if (seen.has(it.go_slug)) continue;
      seen.add(it.go_slug);
      paths.push({ params: { slug: it.go_slug }, props: { target: it.target_url } });
    }
  }
  return paths;
}

const { target } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href={target} />
    <script is:inline set:html={`window.location.replace(${JSON.stringify(target)});`}></script>
  </head>
  <body>
    <p>Redirecting to <a href={target} rel="nofollow sponsored noopener">{target}</a>…</p>
  </body>
</html>
